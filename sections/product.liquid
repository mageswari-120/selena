{%- comment -%}
  Product page — Selena Theme
  OS 2.0 content_for 'block' pattern.
  Section renders two fixed named blocks:
    • media        → blocks/product-media.liquid
    • product_info → blocks/product-info.liquid  (uses content_for 'blocks' internally)
  The product_info block's children are the draggable info sub-blocks.
{%- endcomment -%}

{%- liquid
  assign container_class = 'product-section__inner'
  if section.settings.layout == 'full_width'
    assign container_class = 'product-section__inner product-section__inner--full'
  elsif section.settings.layout == 'container_fluid'
    assign container_class = 'product-section__inner product-section__inner--fluid'
  endif
-%}

<div
  class="product-section color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
  style="
    --product-pt: {{ section.settings.padding_top }}px;
    --product-pb: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="{{ container_class }}">
    {% content_for 'block', type: 'product-media', id: 'product_media' %}
    {% content_for 'block', type: 'product-info',  id: 'product_info' %}
  </div>
</div>

{% stylesheet %}
  .product-section {
    padding-top: var(--product-pt, 60px);
    padding-bottom: var(--product-pb, 60px);
  }

  /* ── Color schemes ── */
  .color-scheme-1 { background: var(--color-background); color: var(--color-foreground); }
  .color-scheme-2 { background: var(--color-secondary, #f5f5f5); color: var(--color-foreground); }
  .color-scheme-3 { background: var(--color-primary); color: var(--color-background); }

  /* ── Container types ── */
  .product-section__inner {
    max-width: var(--page-width, 1400px);
    margin-inline: auto;
    padding-inline: var(--page-margin, 20px);
    display: grid;
    grid-template-columns: var(--product-media-width, 55%) 1fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }
  .product-section__inner--full {
    max-width: 100%;
    padding-inline: 0;
  }
  .product-section__inner--fluid {
    max-width: 100%;
    padding-inline: var(--page-margin, 20px);
  }
  @media (max-width: 768px) {
    .product-section__inner { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Container type",
      "options": [
        { "value": "container",       "label": "Container" },
        { "value": "full_width",      "label": "Full width" },
        { "value": "container_fluid", "label": "Container fluid" }
      ],
      "default": "container"
    },
    {
      "type": "header",
      "content": "Color scheme"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1 — Default" },
        { "value": "scheme-2", "label": "Scheme 2 — Subtle" },
        { "value": "scheme-3", "label": "Scheme 3 — Inverse" }
      ],
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0, "max": 150, "step": 2, "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0, "max": 150, "step": 2, "unit": "px",
      "default": 60
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
