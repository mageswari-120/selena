{% comment %}
  Product page section — media gallery, info, and add-to-cart form.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

<div class="product" data-section-id="{{ section.id }}">

  {%- comment -%} ── Media gallery ── {%- endcomment -%}
  <div class="product__media">
    {% for image in product.images %}
      {% render 'image',
        class: 'product__image',
        image: image,
        width: 900,
        height: 900,
        crop: 'center'
      %}
    {% endfor %}
  </div>

  {%- comment -%} ── Product info ── {%- endcomment -%}
  <div class="product__info">

    {% if section.settings.show_vendor and product.vendor != blank %}
      <p class="product__vendor">{{ product.vendor }}</p>
    {% endif %}

    <h1 class="product__title">{{ product.title }}</h1>

    <div class="product__price">
      <span>{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        <s class="product__price--compare">{{ product.compare_at_price | money }}</s>
      {% endif %}
    </div>

    {% if section.settings.show_description %}
      <div class="product__description">{{ product.description }}</div>
    {% endif %}

    {%- comment -%} ── Add-to-cart form ── {%- endcomment -%}
    <div class="product__form">
      <product-form
        data-cart-add-url="{{ routes.cart_add_url }}"
        data-cart-url="{{ routes.cart_url }}"
      >
        {% form 'product', product %}
          {% assign current_variant = product.selected_or_first_available_variant %}

          {% unless product.has_only_default_variant %}
            <div class="product__variants">
              <select name="id" aria-label="{{ 'products.quantity' | t }}">
                {% for variant in product.variants %}
                  <option
                    value="{{ variant.id }}"
                    {% if variant.available == false %}disabled{% endif %}
                    {% if variant == current_variant %}selected="selected"{% endif %}
                  >
                    {{ variant.title }} — {{ variant.price | money }}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% else %}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {% endunless %}

          {% if section.settings.show_quantity_selector %}
            <div class="product__quantity">
              <label for="Quantity-{{ section.id }}">{{ 'products.quantity' | t }}</label>
              <input
                id="Quantity-{{ section.id }}"
                type="number"
                name="quantity"
                min="1"
                value="1"
              >
            </div>
          {% else %}
            <input type="hidden" name="quantity" value="1">
          {% endif %}

          <button
            type="submit"
            name="add"
            class="product__add-to-cart button button--primary"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {% if current_variant.available %}
              {{ 'products.add_to_cart' | t }}
            {% else %}
              {{ 'products.sold_out' | t | default: 'Sold out' }}
            {% endif %}
          </button>

          {% if section.settings.show_dynamic_checkout %}
            {{ form | payment_button }}
          {% endif %}
        {% endform %}
      </product-form>
    </div>

  </div>
</div>

{% stylesheet %}
  .product {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding: var(--section-padding-fluid, 3rem) var(--page-margin, 20px);
    max-width: var(--page-width, 1400px);
    margin-inline: auto;
  }
  @media (max-width: 768px) {
    .product { grid-template-columns: 1fr; }
  }
  .product__vendor {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.6;
    margin: 0 0 0.5rem;
  }
  .product__title { margin: 0 0 1rem; }
  .product__price {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    margin-bottom: 1.25rem;
    font-size: 1.2rem;
    font-weight: 600;
  }
  .product__price--compare {
    opacity: 0.5;
    font-weight: normal;
    font-size: 1rem;
  }
  .product__description { margin-bottom: 1.5rem; }
  .product__variants select,
  .product__quantity input {
    border-radius: var(--input-border-radius, 0px);
  }
  .product__quantity {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1rem 0;
  }
  .product__quantity input {
    width: 4rem;
    padding: 0.5rem;
    border: 1px solid currentColor;
  }
  .product__add-to-cart {
    display: block;
    width: 100%;
    padding: var(--button-padding-vertical, 14px) var(--button-padding-horizontal, 28px);
    background-color: var(--color-primary);
    color: var(--color-background);
    border: 1px solid var(--color-primary-border);
    border-radius: var(--button-border-radius, 0px);
    cursor: pointer;
    font: inherit;
    font-size: 1rem;
    margin-top: 1rem;
  }
  .product__add-to-cart:hover {
    background-color: var(--color-primary-hover);
  }
  .product__add-to-cart:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Product info"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "header",
      "content": "Purchase options"
    },
    {
      "type": "checkbox",
      "id": "show_quantity_selector",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout buttons",
      "info": "Shows payment buttons like Shop Pay, PayPal, and Google Pay.",
      "default": true
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 60
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
