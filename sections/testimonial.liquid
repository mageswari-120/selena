{%- comment -%}
  Section  : testimonial.liquid
  Theme    : Selena — SHThemes
  Pattern  : OS 3.0 content_for 'block' — fixed named slots + Bootstrap 5
  Prefix   : wdt-
{%- endcomment -%}
{%- liquid
  assign sec_id       = section.id
  assign color_scheme = section.settings.color_scheme
  assign pt           = section.settings.padding_top
  assign pb           = section.settings.padding_bottom

  if section.settings.enable_container
    if section.settings.width_type == 'container_fluid'
      assign wrap_class = 'container-fluid'
    else
      assign wrap_class = 'container'
    endif
  else
    assign wrap_class = 'w-100 px-0'
  endif
-%}

{{ 'bootstrap.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bootstrap.bundle.min.js' | asset_url }}" defer></script>

<div
  class="wdt-testimonial color-{{ color_scheme }}"
  id="wdt-testimonial-{{ sec_id }}"
  data-section-id="{{ sec_id }}"
  style="
    --wdt-sec-pt: {{ pt }}px;
    --wdt-sec-pb: {{ pb }}px;
  "
>
  <div class="{{ wrap_class }}">
    {% content_for 'block', type: 'wdt-header', id: 'wdt_header' %}
    {% content_for 'block', type: 'wdt-content', id: 'wdt_content' %}
  </div>
</div>

{% stylesheet %}

.wdt-testimonial {
  padding-top: var(--wdt-sec-pt, 40px);
  padding-bottom: var(--wdt-sec-pb, 40px);
  background-color: var(--color-background, #fff);
  color: var(--color-foreground, #1a1a1a);
}

{% endstylesheet %}

{% schema %}
{
  "name": "Testimonial",
  "tag": "section",
  "class": "shopify-section--testimonial",
  "blocks": [
    { "type": "wdt-header" },
    { "type": "wdt-content" }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Container"
    },
    {
      "type": "checkbox",
      "id": "enable_container",
      "label": "Enable Container",
      "default": true
    },
    {
      "type": "select",
      "id": "width_type",
      "label": "Width",
      "options": [
        { "value": "full_width",      "label": "Full Width" },
        { "value": "container_fluid", "label": "Container Fluid" }
      ],
      "default": "full_width"
    },
    {
      "type": "header",
      "content": "Color Scheme"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0, "max": 200, "step": 2, "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0, "max": 200, "step": 2, "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Overlay grid",
      "blocks": {
        "wdt_header": {
          "type": "wdt-header",
          "static": true,
          "blocks": {
            "heading": {
              "type": "wdt-heading",
              "settings": {
                "heading": "Shop our latest collection",
                "tag": "h2"
              }
            },
            "description": {
              "type": "wdt-description",
              "settings": {
                "description": "<p>Best selling products</p>"
              }
            }
          },
          "block_order": ["heading", "description"]
        },
        "wdt_content": {
          "type": "wdt-content",
          "static": true,
          "settings": {
            "layout_type": "grid",
            "columns_desktop": "4",
            "columns_mobile": "1"
          },
          "blocks": {
            "card_1": {
              "type": "wdt-card",
              "settings": { "card_type": "overlay", "card_alignment": "start" },
              "blocks": {
                "image": { "type": "wdt-image-static" },
                "description": {
                  "type": "wdt-card-description",
                  "settings": {
                    "description": "<p>The fabric quality exceeded my expectations. Will definitely order again.</p>"
                  }
                },
                "client": {
                  "type": "wdt-client-details",
                  "settings": { "name": "Priya Sharma", "profession": "Chennai", "image_position": "left" }
                },
                "rating": { "type": "wdt-custom-rating", "settings": { "rating_count": "5", "rating_color": "#f5c518" } }
              },
              "block_order": ["image", "description", "client", "rating"]
            }
          },
          "block_order": ["card_1"]
        }
      }
    },
    {
      "name": "Client says carousel",
      "blocks": {
        "wdt_header": {
          "type": "wdt-header",
          "static": true,
          "blocks": {
            "description": {
              "type": "wdt-description",
              "settings": { "description": "<p><em>About Style</em></p>" }
            },
            "heading": {
              "type": "wdt-heading",
              "settings": { "heading": "Client Says" }
            }
          },
          "block_order": ["description", "heading"]
        },
        "wdt_content": {
          "type": "wdt-content",
          "static": true,
          "settings": {
            "layout_type": "carousel",
            "nav_style": "navigation",
            "slides_desktop": "1"
          },
          "blocks": {
            "card_1": {
              "type": "wdt-card",
              "settings": { "card_type": "grid", "card_image_position": "top", "card_alignment": "center" },
              "blocks": {
                "image": { "type": "wdt-image-static" },
                "rating": { "type": "wdt-custom-rating", "settings": { "rating_count": "5" } },
                "description": {
                  "type": "wdt-card-description",
                  "settings": { "description": "<p>The attention to detail is incredible.</p>" }
                },
                "client": {
                  "type": "wdt-client-details",
                  "settings": { "name": "Sophia Bennett", "profession": "Customer" }
                }
              },
              "block_order": ["image", "rating", "description", "client"]
            }
          },
          "block_order": ["card_1"]
        }
      }
    },
    {
      "name": "Real stories",
      "blocks": {
        "wdt_header": {
          "type": "wdt-header",
          "static": true,
          "blocks": {
            "heading": {
              "type": "wdt-heading",
              "settings": { "heading": "Real Stories", "tag": "h2" }
            }
          },
          "block_order": ["heading"]
        },
        "wdt_content": {
          "type": "wdt-content",
          "static": true,
          "settings": {
            "layout_type": "grid",
            "columns_desktop": "3",
            "columns_mobile": "1"
          },
          "blocks": {
            "card_1": {
              "type": "wdt-card",
              "settings": {
                "card_type": "grid",
                "card_image_position": "right",
                "card_alignment": "start",
                "card_border_style": "solid",
                "card_border_radius": 8
              },
              "blocks": {
                "rating": { "type": "wdt-custom-rating", "settings": { "rating_count": "5" } },
                "client": { "type": "wdt-client-details", "settings": { "name": "Aditi R.", "profession": "Los Angeles" } },
                "heading": { "type": "wdt-card-heading", "settings": { "heading": "Finally Found A Serum" } },
                "description": {
                  "type": "wdt-card-description",
                  "settings": { "description": "<p>My skin has never looked better.</p>" }
                },
                "image": { "type": "wdt-image-static" }
              },
              "block_order": ["rating", "client", "heading", "description", "image"]
            }
          },
          "block_order": ["card_1"]
        }
      }
    },
    {
      "name": "Happy customers",
      "blocks": {
        "wdt_header": {
          "type": "wdt-header",
          "static": true,
          "blocks": {
            "description": {
              "type": "wdt-description",
              "settings": { "description": "<p>The Latest Actions</p>" }
            },
            "heading": {
              "type": "wdt-heading",
              "settings": { "heading": "Hear From Our Happy Customers" }
            },
            "button": {
              "type": "wdt-button",
              "settings": { "label": "View all reviews", "style": "primary" }
            }
          },
          "block_order": ["description", "heading", "button"]
        },
        "wdt_content": {
          "type": "wdt-content",
          "static": true,
          "settings": {
            "layout_type": "carousel",
            "slides_desktop": "2",
            "nav_style": "both",
            "border_style": "solid",
            "border_radius": 12,
            "inherit_color_scheme": false,
            "content_color_scheme": "scheme-2"
          },
          "blocks": {
            "card_1": {
              "type": "wdt-card",
              "settings": { "card_type": "grid", "card_image_position": "top", "card_alignment": "center" },
              "blocks": {
                "image": { "type": "wdt-image-static" },
                "rating": { "type": "wdt-custom-rating", "settings": { "rating_count": "5" } },
                "description": {
                  "type": "wdt-card-description",
                  "settings": { "description": "<p>Our family loves these products.</p>" }
                },
                "client": {
                  "type": "wdt-client-details",
                  "settings": { "name": "The Martinez Family", "profession": "Verified buyer" }
                }
              },
              "block_order": ["image", "rating", "description", "client"]
            },
            "card_2": {
              "type": "wdt-card",
              "settings": { "card_type": "grid", "card_image_position": "top", "card_alignment": "center" },
              "blocks": {
                "image": { "type": "wdt-image-static" },
                "rating": { "type": "wdt-custom-rating", "settings": { "rating_count": "5" } },
                "description": {
                  "type": "wdt-card-description",
                  "settings": { "description": "<p>Exceeded expectations from start to finish.</p>" }
                },
                "client": {
                  "type": "wdt-client-details",
                  "settings": { "name": "Emily Chen", "profession": "Verified buyer" }
                }
              },
              "block_order": ["image", "rating", "description", "client"]
            }
          },
          "block_order": ["card_1", "card_2"]
        }
      }
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
