{% comment %}
  Collection page section.
  Product cards rendered via {% render 'product-card' %} snippet.
{% endcomment %}

<div
  class="collection"
  data-section-id="{{ section.id }}"
  style="
    --collection-pt: {{ section.settings.padding_top }}px;
    --collection-pb: {{ section.settings.padding_bottom }}px;
  "
>

  {%- comment -%}── Banner ──{%- endcomment -%}
  {%- if section.settings.show_collection_image and collection.image -%}
    <div class="collection__banner">
      {{- collection.image
        | image_url: width: 2000
        | image_tag:
          class: 'collection__banner-img',
          widths: '800,1200,1600,2000',
          sizes: '100vw',
          loading: 'lazy',
          alt: collection.image.alt | escape | default: collection.title | escape
      -}}
    </div>
  {%- endif -%}

  {%- comment -%}── Header ──{%- endcomment -%}
  <div class="collection__header">
    {%- if section.settings.show_title -%}
      <h1 class="collection__title">{{ collection.title }}</h1>
    {%- endif -%}
    {%- if section.settings.show_description and collection.description != blank -%}
      <div class="collection__description rte">{{ collection.description }}</div>
    {%- endif -%}
  </div>

  {%- comment -%}── Toolbar: sort ──{%- endcomment -%}
  {%- if section.settings.enable_sorting -%}
    <div class="collection__toolbar">
      <label class="collection__sort-label" for="CollectionSort-{{ section.id }}">
        {{- 'collections.sort_by' | t | default: 'Sort by' -}}
      </label>
      <select
        id="CollectionSort-{{ section.id }}"
        class="collection__sort-select"
        name="sort_by"
        aria-label="{{ 'collections.sort_by' | t | default: 'Sort by' }}"
      >
        <option value="manual"{% if collection.sort_by == 'manual' %} selected{% endif %}>{{ 'collections.sort.featured' | t | default: 'Featured' }}</option>
        <option value="best-selling"{% if collection.sort_by == 'best-selling' %} selected{% endif %}>{{ 'collections.sort.best_selling' | t | default: 'Best selling' }}</option>
        <option value="title-ascending"{% if collection.sort_by == 'title-ascending' %} selected{% endif %}>{{ 'collections.sort.az' | t | default: 'A–Z' }}</option>
        <option value="title-descending"{% if collection.sort_by == 'title-descending' %} selected{% endif %}>{{ 'collections.sort.za' | t | default: 'Z–A' }}</option>
        <option value="price-ascending"{% if collection.sort_by == 'price-ascending' %} selected{% endif %}>{{ 'collections.sort.price_asc' | t | default: 'Price: low to high' }}</option>
        <option value="price-descending"{% if collection.sort_by == 'price-descending' %} selected{% endif %}>{{ 'collections.sort.price_desc' | t | default: 'Price: high to low' }}</option>
        <option value="created-descending"{% if collection.sort_by == 'created-descending' %} selected{% endif %}>{{ 'collections.sort.newest' | t | default: 'Newest' }}</option>
      </select>
    </div>
  {%- endif -%}

  {%- comment -%}── Product grid ──{%- endcomment -%}
  {%- paginate collection.products by section.settings.products_per_page -%}

    <div
      class="collection__grid"
      style="--cols: {{ section.settings.columns_desktop }}; --cols-mobile: {{ section.settings.columns_mobile }};"
    >
      {%- for product in collection.products -%}
        {%- render 'product-card',
          product: product,
          info_layout:    section.settings.card_layout,
          image_ratio:    section.settings.image_ratio,
          show_vendor:    section.settings.show_vendor,
          show_rating:    section.settings.show_rating,
          show_swatches:  section.settings.show_swatches,
          show_wishlist:  section.settings.show_wishlist,
          show_quick_add: section.settings.show_quick_add,
          lazy:           'lazy'
        -%}
      {%- else -%}
        <p class="collection__empty">{{ 'collections.empty' | t | default: 'No products found.' }}</p>
      {%- endfor -%}
    </div>

    {%- comment -%}── Pagination ──{%- endcomment -%}
    {%- if section.settings.pagination_style == 'numbers' and paginate.pages > 1 -%}
      <div class="collection__pagination">
        {{- paginate | default_pagination -}}
      </div>
    {%- endif -%}

  {%- endpaginate -%}

</div>

{% stylesheet %}
  .collection {
    max-width: var(--page-width, 1400px);
    margin-inline: auto;
    padding-inline: var(--page-margin, 20px);
    padding-top: var(--collection-pt, 40px);
    padding-bottom: var(--collection-pb, 40px);
  }

  /* Banner */
  .collection__banner { margin-bottom: 2rem; }
  .collection__banner-img { width: 100%; max-height: 400px; object-fit: cover; display: block; }

  /* Header */
  .collection__header { margin-bottom: 1.75rem; }
  .collection__title  { margin: 0 0 0.5rem; }
  .collection__description { font-size: 0.95rem; opacity: 0.75; }

  /* Toolbar */
  .collection__toolbar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }
  .collection__sort-label { font-size: 0.85rem; opacity: 0.7; white-space: nowrap; }
  .collection__sort-select {
    padding: 0.4rem 0.7rem;
    border: 1px solid rgba(0,0,0,0.2);
    border-radius: var(--input-border-radius, 0px);
    background: var(--color-background);
    color: var(--color-foreground);
    font: inherit;
    font-size: 0.85rem;
    cursor: pointer;
  }

  /* Grid */
  .collection__grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), 1fr);
    gap: clamp(0.75rem, 2vw, 1.5rem);
  }
  @media (max-width: 768px) {
    .collection__grid { grid-template-columns: repeat(var(--cols-mobile, 2), 1fr); }
  }
  @media (max-width: 400px) {
    .collection__grid { grid-template-columns: 1fr; }
  }

  /* Empty */
  .collection__empty { grid-column: 1 / -1; padding: 3rem 0; text-align: center; opacity: 0.6; }

  /* Pagination */
  .collection__pagination { margin-top: 2.5rem; text-align: center; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Collection header"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection description",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "Show banner image",
      "default": false
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "select",
      "id": "card_layout",
      "label": "Card info layout",
      "options": [
        { "value": "below",   "label": "Info below image" },
        { "value": "overlay", "label": "Info overlaid on image" },
        { "value": "side",    "label": "Side by side" }
      ],
      "default": "below"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square",    "label": "Square (1:1)" },
        { "value": "portrait",  "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (4:3)" },
        { "value": "natural",   "label": "Natural (as uploaded)" }
      ],
      "default": "square"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating",
      "default": false,
      "info": "Uses product.metafields.reviews.rating — requires a reviews app."
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "Show color swatches",
      "default": false,
      "info": "Reads variants with option name 'Color' or 'Colour'."
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist button",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4, "max": 48, "step": 4,
      "default": 24
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns — desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns — mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Sorting"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sort by",
      "default": true
    },
    {
      "type": "header",
      "content": "Pagination"
    },
    {
      "type": "select",
      "id": "pagination_style",
      "label": "Pagination style",
      "options": [
        { "value": "numbers", "label": "Page numbers" },
        { "value": "none",    "label": "None" }
      ],
      "default": "numbers"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0, "max": 150, "step": 2, "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0, "max": 150, "step": 2, "unit": "px",
      "default": 40
    }
  ]
}
{% endschema %}
