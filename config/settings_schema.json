  {
    "name": "t:name.layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 80,
        "max": 120,
        "step": 1,
        "default": 102,
        "unit": "rem",
        "label": "t:settings.page_width"
      },
      {
        "type": "range",
        "id": "page_edge_spacing",
        "min": 0.5,
        "max": 2,
        "step": 0.1,
        "default": 1,
        "unit": "rem",
        "label": "t:settings.page_edge_spacing"
      },
      {
        "type": "checkbox",
        "id": "enable_scroll_to_top",
        "default": false,
        "label": "t:settings.scroll_top"
      }
    ]
  },
  {
    "name": "t:name.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:content.headings"
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "t:settings.font",
        "info": "t:info.typography_font_info",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "min": 90,
        "max": 125,
        "step": 1,
        "unit": "%",
        "label": "t:settings.font_size_scale",
        "default": 100
      },
      {
        "type": "select",
        "id": "heading_transform",
        "options": [
          {
            "value": "uppercase",
            "label": "t:options.uppercase"
          },
          {
            "value": "none",
            "label": "t:options.default"
          }
        ],
        "default": "none",
        "label": "t:settings.font_transform",
        "info": "t:info.font_transform"
      },
      {
        "type": "range",
        "id": "heading_line_height",
        "min": 1,
        "max": 2,
        "step": 0.1,
        "label": "t:settings.heading_line_height",
        "default": 1
      },
      {
        "type": "header",
        "content": "t:content.body"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "default": "assistant_n4",
        "label": "t:settings.font",
        "info": "t:info.typography_font_info"
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 90,
        "max": 125,
        "step": 1,
        "unit": "%",
        "label": "t:settings.font_size_scale",
        "default": 100
      },
      {
        "type": "range",
        "id": "body_line_height",
        "min": 1,
        "max": 2,
        "step": 0.1,
        "label": "t:settings.body_line_height",
        "default": 1
      },
      {
        "type": "header",
        "content": "t:settings_schema.typography.heading_font"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "josefin_sans_n4",
        "label": "t:settings_schema.typography.heading_font"
      },
      {
        "type": "range",
        "id": "type_heading_scale",
        "min": 70,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "t:settings_schema.typography.heading_scale",
        "default": 100
      },
      {
        "type": "header",
        "content": "t:settings_schema.typography.body_font"
