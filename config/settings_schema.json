        "label": "t:settings.favicon_image",
        "info": "t:info.favicon_info"
      }
    ]
  },
  {
    "name": "t:name.layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 80,
        "max": 120,
        "step": 1,
        "default": 102,
        "unit": "rem",
        "label": "t:settings.page_width"
      },
      {
        "type": "range",
        "id": "page_edge_spacing",
        "min": 0.5,
        "max": 2,
        "step": 0.1,
        "default": 1,
        "unit": "rem",
        "label": "t:settings.page_edge_spacing"
      },
      {
        "type": "checkbox",
        "id": "enable_scroll_to_top",
        "default": false,
        "label": "t:settings.scroll_top"
      }
    ]
  },
  {
    "name": "t:name.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:content.headings"
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "t:settings.font",
        "info": "t:info.typography_font_info",
        "default": "assistant_n4"
      },
      {
        "type": "select",
        "id": "heading_transform",
        "options": [
          {
            "value": "uppercase",
            "label": "t:options.uppercase"
          },
          {
            "value": "none",
            "label": "t:options.default"
          }
        ],
        "default": "none",
        "label": "t:settings.font_transform",
        "info": "t:info.font_transform"
      },
      {
        "type": "range",
        "id": "heading_line_height",
        "min": 1,
        "max": 2,
        "step": 0.1,
        "label": "t:settings.heading_line_height",
        "default": 1
      },
      {
        "type": "range",
        "id": "h1_heading",
        "min": 64,
        "max": 90,
        "step": 1,
        "unit": "px",
        "label": "t:settings.h1_heading",
        "default": 64
      },
      {
        "type": "range",
        "id": "h2_heading",
        "min": 48,
        "max": 64,
        "step": 1,
        "unit": "px",
        "label": "t:settings.h2_heading",
        "default": 48
      },
      {
        "type": "range",
        "id": "h3_heading",
        "min": 32,
        "max": 48,
        "step": 1,
        "unit": "px",
        "label": "t:settings.h3_heading",
        "default": 32
      },
      {
        "type": "range",
        "id": "h4_heading",
        "min": 22,
        "max": 32,
        "step": 1,
        "unit": "px",
        "label": "t:settings.h4_heading",
        "default": 22
      },
      {
        "type": "range",
        "id": "h5_heading",
        "min": 18,
        "max": 26,
        "step": 1,
        "unit": "px",
        "label": "t:settings.h5_heading",
        "default": 18
      },
      {
        "type": "range",
        "id": "h6_heading",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "t:settings.h6_heading",
        "default": 16
      },
      {
        "type": "header",
        "content": "t:content.body"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "default": "assistant_n4",
        "label": "t:settings.font",
        "info": "t:info.typography_font_info"
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 90,
        "max": 125,
        "step": 1,
        "unit": "%",
        "label": "t:settings.font_size_scale",
        "default": 100
      },
      {
        "type": "range",
        "id": "body_line_height",
        "min": 1,
        "max": 2,
        "step": 0.1,
        "label": "t:settings.body_line_height",
        "default": 1
      }
    ]
  },
