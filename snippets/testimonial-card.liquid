{%- comment -%}
  ══════════════════════════════════════════════════════════════════════════
  Snippet  : testimonial-card.liquid
  Theme    : Selena — SHThemes
  Prefix   : wdt-
  Usage    : {% render 'testimonial-card', block: card %}
  Renders  : One testimonial card with all 5 sub-blocks:
               image_static · card_heading · card_description
               custom_rating · client_details
  ══════════════════════════════════════════════════════════════════════════
{%- endcomment -%}

{%- liquid 
  comment ── Card settings shorthand ──
  endcomment
  assign card_type          = block.settings.card_type           | default: 'grid'
  assign img_pos            = block.settings.card_image_position | default: 'top'
  assign alignment          = block.settings.card_alignment      | default: 'center'
  assign card_gap           = block.settings.card_gap            | default: 10
  assign enable_overlay     = block.settings.enable_overlay      | default: false
  assign overlay_color      = block.settings.overlay_color       | default: '#000000'
  assign overlay_style      = block.settings.overlay_style       | default: 'solid'
  assign overlay_direction  = block.settings.overlay_direction   | default: 'to bottom'
  assign inherit_scheme     = block.settings.inherit_color_scheme | default: true
  assign card_scheme        = block.settings.card_color_scheme   | default: 'scheme-1'
  assign border_style       = block.settings.card_border_style   | default: 'none'
  assign border_width       = block.settings.card_border_width   | default: 1
  assign border_opacity     = block.settings.card_border_opacity | default: 100
  assign border_radius      = block.settings.card_border_radius  | default: 0
  assign card_pt            = block.settings.card_pt             | default: 20
  assign card_pb            = block.settings.card_pb             | default: 20
  assign card_pl            = block.settings.card_pl             | default: 20
  assign card_pr            = block.settings.card_pr             | default: 20

  comment ── Sub-block: image_static ──
  endcomment
  assign s_image  = block.settings.image
  assign s_img_pt = block.settings.img_pt | default: 0
  assign s_img_pb = block.settings.img_pb | default: 0
  assign s_img_pl = block.settings.img_pl | default: 0
  assign s_img_pr = block.settings.img_pr | default: 0

  comment ── Sub-block: card_heading ──
  endcomment
  assign s_heading = block.settings.heading
  assign s_hdg_pt  = block.settings.hdg_pt | default: 10
  assign s_hdg_pb  = block.settings.hdg_pb | default: 10
  assign s_hdg_pl  = block.settings.hdg_pl | default: 0
  assign s_hdg_pr  = block.settings.hdg_pr | default: 0

  comment ── Sub-block: card_description ──
  endcomment
  assign s_desc    = block.settings.description
  assign s_desc_pt = block.settings.desc_pt | default: 0
  assign s_desc_pb = block.settings.desc_pb | default: 10
  assign s_desc_pl = block.settings.desc_pl | default: 0
  assign s_desc_pr = block.settings.desc_pr | default: 0

  comment ── Sub-block: custom_rating ──
  endcomment
  assign s_rating       = block.settings.rating_count  | default: '5'
  assign s_rating_color = block.settings.rating_color  | default: '#F59E0B'
  assign s_rating_gap   = block.settings.rating_gap    | default: 4
  assign s_rating_pt    = block.settings.rating_pt     | default: 0
  assign s_rating_pb    = block.settings.rating_pb     | default: 10
  assign s_rating_pl    = block.settings.rating_pl     | default: 0
  assign s_rating_pr    = block.settings.rating_pr     | default: 0
  assign rating_num     = s_rating | times: 1.0

  comment ── Sub-block: client_details ──
  endcomment
  assign s_client_img    = block.settings.client_image
  assign s_client_name   = block.settings.client_name       | default: 'John'
  assign s_client_prof   = block.settings.client_profession | default: 'Director'
  assign s_client_imgpos = block.settings.client_image_position | default: 'top'
  assign s_client_ar     = block.settings.client_aspect_ratio   | default: 'circle'
  assign s_client_gap    = block.settings.client_gap         | default: 10
  assign s_client_pt     = block.settings.client_pt          | default: 10
  assign s_client_pb     = block.settings.client_pb          | default: 0
  assign s_client_pl     = block.settings.client_pl          | default: 0
  assign s_client_pr     = block.settings.client_pr          | default: 0

  comment ── Border opacity → rgba ──
  endcomment
  assign border_opacity_dec = border_opacity | divided_by: 100.0

  comment ── Overlay CSS value ──
  endcomment
  if enable_overlay
    if overlay_style == 'gradient'
      assign overlay_css = 'linear-gradient(' | append: overlay_direction | append: ', ' | append: overlay_color | append: 'cc, transparent)'
    else
      assign overlay_css = overlay_color | append: '26'
    endif
  endif

  comment ── Color scheme class ──
  endcomment
  unless inherit_scheme
    assign card_scheme_class = 'color-' | append: card_scheme
  else
    assign card_scheme_class = ''
  endunless

  comment ── Layout modifier class ──
  endcomment
  assign card_layout_class = 'wdt-tc--' | append: card_type
  if card_type == 'grid'
    assign card_layout_class = card_layout_class | append: ' wdt-tc--img-' | append: img_pos
  endif

  comment ── Alignment class ──
  endcomment
  assign align_class = 'text-' | append: alignment
-%}

{%- comment -%}── Card root ──{%- endcomment -%}
<article
  class="wdt-tc {{ card_layout_class }} {{ card_scheme_class }} {{ align_class }}"
  {{ block.shopify_attributes }}
  style="
    --wdt-tc-gap: {{ card_gap }}px;
    --wdt-tc-pt: {{ card_pt }}px;
    --wdt-tc-pb: {{ card_pb }}px;
    --wdt-tc-pl: {{ card_pl }}px;
    --wdt-tc-pr: {{ card_pr }}px;
    {% if border_style == 'solid' %}
      --wdt-tc-border: {{ border_width }}px solid rgba({{ block.settings.card_border_style | replace: 'solid', '' }}0,0,0,{{ border_opacity_dec }});
      --wdt-tc-radius: {{ border_radius }}px;
    {% else %}
      --wdt-tc-border: none;
      --wdt-tc-radius: 0px;
    {% endif %}
    {% if enable_overlay %}
      --wdt-tc-overlay: {{ overlay_css }};
    {% endif %}
  "
>

  {%- comment -%}── Overlay layer ──{%- endcomment -%}
  {%- if enable_overlay -%}
    <div class="wdt-tc__overlay" aria-hidden="true"></div>
  {%- endif -%}

  {%- comment -%}══════════════════════════════
    SUB-BLOCK: image_static
  ══════════════════════════════{%- endcomment -%}
  {%- if s_image != blank -%}
    <div
      class="wdt-tc__image-wrap"
      style="
        padding-top: {{ s_img_pt }}px;
        padding-bottom: {{ s_img_pb }}px;
        padding-left: {{ s_img_pl }}px;
        padding-right: {{ s_img_pr }}px;
      "
    >
      {{- s_image
        | image_url: width: 800
        | image_tag:
          class: 'wdt-tc__image',
          widths: '200,400,600,800',
          sizes: '(max-width: 576px) 100vw, 33vw',
          loading: 'lazy',
          alt: s_image.alt | escape | default: s_client_name | escape
      -}}
    </div>
  {%- endif -%}

  {%- comment -%}── Content wrapper ──{%- endcomment -%}
  <div class="wdt-tc__body">

    {%- comment -%}══════════════════════════════
      SUB-BLOCK: custom_rating
    ══════════════════════════════{%- endcomment -%}
    <div
      class="wdt-tc__rating"
      aria-label="{{ rating_num }} out of 5 stars"
      style="
        --wdt-star-color: {{ s_rating_color }};
        --wdt-star-gap: {{ s_rating_gap }}px;
        padding-top: {{ s_rating_pt }}px;
        padding-bottom: {{ s_rating_pb }}px;
        padding-left: {{ s_rating_pl }}px;
        padding-right: {{ s_rating_pr }}px;
      "
    >
      {%- comment -%}── 5 stars, fill via clip-path percentage ──{%- endcomment -%}
      <span
        class="wdt-tc__stars"
        style="--wdt-rating-pct: {{ rating_num | divided_by: 5.0 | times: 100 }}%;"
        aria-hidden="true"
      >
        <span class="wdt-tc__stars-empty">★★★★★</span>
        <span class="wdt-tc__stars-fill">★★★★★</span>
      </span>
    </div>

    {%- comment -%}══════════════════════════════
      SUB-BLOCK: card_heading
    ══════════════════════════════{%- endcomment -%}
    {%- if s_heading != blank -%}
      <blockquote
        class="wdt-tc__heading"
        style="
          padding-top: {{ s_hdg_pt }}px;
          padding-bottom: {{ s_hdg_pb }}px;
          padding-left: {{ s_hdg_pl }}px;
          padding-right: {{ s_hdg_pr }}px;
        "
      >
        {{- s_heading | escape -}}
      </blockquote>
    {%- endif -%}

    {%- comment -%}══════════════════════════════
      SUB-BLOCK: card_description
    ══════════════════════════════{%- endcomment -%}
    {%- if s_desc != blank -%}
      <div
        class="wdt-tc__desc rte"
        style="
          padding-top: {{ s_desc_pt }}px;
          padding-bottom: {{ s_desc_pb }}px;
          padding-left: {{ s_desc_pl }}px;
          padding-right: {{ s_desc_pr }}px;
        "
      >
        {{- s_desc -}}
      </div>
    {%- endif -%}

    {%- comment -%}══════════════════════════════
      SUB-BLOCK: client_details
    ══════════════════════════════{%- endcomment -%}
    <div
      class="wdt-tc__client wdt-tc__client--{{ s_client_imgpos }}"
      style="
        --wdt-client-gap: {{ s_client_gap }}px;
        padding-top: {{ s_client_pt }}px;
        padding-bottom: {{ s_client_pb }}px;
        padding-left: {{ s_client_pl }}px;
        padding-right: {{ s_client_pr }}px;
      "
    >

      {%- comment -%}── Client avatar ──{%- endcomment -%}
      {%- if s_client_img != blank -%}
        <div class="wdt-tc__client-img-wrap wdt-tc__client-img-wrap--{{ s_client_ar }}">
          {{- s_client_img
            | image_url: width: 200
            | image_tag:
              class: 'wdt-tc__client-img',
              widths: '80,100,120,160,200',
              sizes: '80px',
              loading: 'lazy',
              alt: s_client_name | escape
          -}}
        </div>
      {%- else -%}
        <div class="wdt-tc__client-img-wrap wdt-tc__client-img-wrap--{{ s_client_ar }} wdt-tc__client-placeholder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 20c0-4 3.582-7 8-7s8 3 8 7"/>
          </svg>
        </div>
      {%- endif -%}

      {%- comment -%}── Client meta ──{%- endcomment -%}
      <div class="wdt-tc__client-meta">
        {%- if s_client_name != blank -%}
          <p class="wdt-tc__client-name">{{ s_client_name | escape }}</p>
        {%- endif -%}
        {%- if s_client_prof != blank -%}
          <p class="wdt-tc__client-prof">{{ s_client_prof | escape }}</p>
        {%- endif -%}
      </div>

    </div>
    {%- comment -%}── /client_details ──{%- endcomment -%}

  </div>
  {%- comment -%}── /wdt-tc__body ──{%- endcomment -%}

</article>
{%- comment -%}── /wdt-tc ──{%- endcomment -%}

{% stylesheet %}

/* ══════════════════════════════════════════════════════════════════
   WDT Testimonial Card — Snippet
   Prefix: wdt-tc-   |   Bootstrap 5 augmentation
══════════════════════════════════════════════════════════════════ */

/* ── Card base ── */
.wdt-tc {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100%;
  padding-top: var(--wdt-tc-pt, 20px);
  padding-bottom: var(--wdt-tc-pb, 20px);
  padding-left: var(--wdt-tc-pl, 20px);
  padding-right: var(--wdt-tc-pr, 20px);
  border: var(--wdt-tc-border, none);
  border-radius: var(--wdt-tc-radius, 0px);
  overflow: hidden;
  background-color: var(--color-background, #fff);
  color: var(--color-foreground, #1a1a1a);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  gap: var(--wdt-tc-gap, 10px);
}
.wdt-tc:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
}

/* ── Overlay ── */
.wdt-tc__overlay {
  position: absolute;
  inset: 0;
  background: var(--wdt-tc-overlay, transparent);
  pointer-events: none;
  z-index: 0;
}
.wdt-tc__overlay ~ * { position: relative; z-index: 1; }

/* ══ Layout: card_type = grid ══ */

/* Image Top (default) */
.wdt-tc--grid.wdt-tc--img-top {
  flex-direction: column;
}
/* Image Bottom */
.wdt-tc--grid.wdt-tc--img-bottom {
  flex-direction: column-reverse;
}
/* Image Left */
.wdt-tc--grid.wdt-tc--img-left {
  flex-direction: row;
  align-items: flex-start;
}
.wdt-tc--grid.wdt-tc--img-left .wdt-tc__image-wrap {
  flex: 0 0 auto;
  max-width: 40%;
}
.wdt-tc--grid.wdt-tc--img-left .wdt-tc__body {
  flex: 1;
}
/* Image Right */
.wdt-tc--grid.wdt-tc--img-right {
  flex-direction: row-reverse;
  align-items: flex-start;
}
.wdt-tc--grid.wdt-tc--img-right .wdt-tc__image-wrap {
  flex: 0 0 auto;
  max-width: 40%;
}
.wdt-tc--grid.wdt-tc--img-right .wdt-tc__body {
  flex: 1;
}

/* ══ Layout: card_type = overlay ══ */
.wdt-tc--overlay {
  position: relative;
  min-height: 280px;
}
.wdt-tc--overlay .wdt-tc__image-wrap {
  position: absolute;
  inset: 0;
  padding: 0 !important;
}
.wdt-tc--overlay .wdt-tc__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.wdt-tc--overlay .wdt-tc__body {
  position: relative;
  z-index: 2;
  margin-top: auto;
}

/* ── Card body ── */
.wdt-tc__body {
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 0;
}

/* ── Static image ── */
.wdt-tc__image-wrap { display: block; }
.wdt-tc__image {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}

/* ══ SUB-BLOCK: custom_rating ══ */
.wdt-tc__rating {
  display: flex;
  justify-content: inherit;
}
.wdt-tc.text-center .wdt-tc__rating { justify-content: center; }
.wdt-tc.text-end    .wdt-tc__rating { justify-content: flex-end; }

.wdt-tc__stars {
  position: relative;
  display: inline-block;
  font-size: 1.1rem;
  letter-spacing: var(--wdt-star-gap, 4px);
  line-height: 1;
}
.wdt-tc__stars-empty {
  color: rgba(0, 0, 0, 0.15);
  display: block;
}
.wdt-tc__stars-fill {
  position: absolute;
  inset: 0;
  overflow: hidden;
  width: var(--wdt-rating-pct, 100%);
  color: var(--wdt-star-color, #f59e0b);
  white-space: nowrap;
  display: block;
}

/* ══ SUB-BLOCK: card_heading ══ */
.wdt-tc__heading {
  font-family: var(--font-heading--family, inherit);
  font-size: clamp(0.95rem, 1.5vw, 1.125rem);
  font-weight: 500;
  font-style: italic;
  line-height: 1.6;
  margin: 0;
  border: none;
  padding: 0;
  color: var(--color-foreground, #1a1a1a);
}

/* ══ SUB-BLOCK: card_description ══ */
.wdt-tc__desc {
  font-size: 0.875rem;
  line-height: 1.75;
  opacity: 0.75;
}
.wdt-tc__desc p { margin-bottom: 0; }

/* ══ SUB-BLOCK: client_details ══ */
.wdt-tc__client {
  display: flex;
  align-items: center;
  gap: var(--wdt-client-gap, 10px);
  margin-top: auto;
}
/* image position: top → stack vertically */
.wdt-tc__client--top {
  flex-direction: column;
  align-items: inherit;
}
/* image position: left → row */
.wdt-tc__client--left {
  flex-direction: row;
  align-items: center;
}

/* center/end alignment overrides for top-stack */
.wdt-tc.text-center .wdt-tc__client--top { align-items: center; }
.wdt-tc.text-end    .wdt-tc__client--top { align-items: flex-end; }

/* ── Client avatar ── */
.wdt-tc__client-img-wrap {
  flex-shrink: 0;
  width: 56px;
  height: 56px;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}
/* aspect ratio variants */
.wdt-tc__client-img-wrap--square  { border-radius: 0; aspect-ratio: 1/1; }
.wdt-tc__client-img-wrap--portrait { border-radius: 0; width: 48px; height: 64px; }
.wdt-tc__client-img-wrap--adapt   { border-radius: 0; width: auto; height: auto; max-width: 80px; }
.wdt-tc__client-img-wrap--circle  { border-radius: 50%; }

.wdt-tc__client-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* placeholder svg */
.wdt-tc__client-placeholder svg {
  width: 60%;
  height: 60%;
  opacity: 0.4;
}

/* ── Client meta text ── */
.wdt-tc__client-meta { display: flex; flex-direction: column; gap: 2px; }

.wdt-tc__client-name {
  font-size: 0.875rem;
  font-weight: 700;
  margin: 0;
  color: var(--color-foreground, #1a1a1a);
  line-height: 1.3;
}
.wdt-tc__client-prof {
  font-size: 0.75rem;
  margin: 0;
  opacity: 0.55;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  line-height: 1.3;
}

/* ── Responsive ── */
@media (max-width: 575.98px) {
  .wdt-tc--grid.wdt-tc--img-left,
  .wdt-tc--grid.wdt-tc--img-right {
    flex-direction: column;
  }
  .wdt-tc--grid.wdt-tc--img-left .wdt-tc__image-wrap,
  .wdt-tc--grid.wdt-tc--img-right .wdt-tc__image-wrap {
    max-width: 100%;
  }
}

{% endstylesheet %}
