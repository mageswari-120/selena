{% comment %}
  css-variables.liquid
  Outputs all theme CSS custom properties.
  Every font filter is guarded with an .system? check — if the merchant
  hasn't saved a font picker value yet (settings_data.json is empty {}),
  the font object is nil and font_face / font_url will throw a Liquid error.
{% endcomment %}

{% style %}

  {% comment %} ── Font @font-face declarations ── {% endcomment %}
  {% unless settings.type_heading_font.system? %}
    {{ settings.type_heading_font | font_face: font_display: 'swap' }}
    {{ settings.type_heading_font | font_modify: 'weight', 'bold'   | font_face: font_display: 'swap' }}
    {{ settings.type_heading_font | font_modify: 'style',  'italic' | font_face: font_display: 'swap' }}
  {% endunless %}

  {% unless settings.type_body_font.system? %}
    {{ settings.type_body_font | font_face: font_display: 'swap' }}
    {{ settings.type_body_font | font_modify: 'weight', 'bold'   | font_face: font_display: 'swap' }}
    {{ settings.type_body_font | font_modify: 'style',  'italic' | font_face: font_display: 'swap' }}
  {% endunless %}

  :root {

    {% comment %} ── Typography ── {% endcomment %}
    {% if settings.type_heading_font.system? or settings.type_heading_font == nil %}
      --font-heading--family: system-ui, sans-serif;
      --font-heading--style:  normal;
      --font-heading--weight: 700;
    {% else %}
      --font-heading--family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
      --font-heading--style:  {{ settings.type_heading_font.style }};
      --font-heading--weight: {{ settings.type_heading_font.weight }};
    {% endif %}
    --font-heading--scale: {{ settings.type_heading_scale | default: 100 | divided_by: 100.0 }};

    {% if settings.type_body_font.system? or settings.type_body_font == nil %}
      --font-body--family: system-ui, sans-serif;
      --font-body--style:  normal;
      --font-body--weight: 400;
    {% else %}
      --font-body--family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
      --font-body--style:  {{ settings.type_body_font.style }};
      --font-body--weight: {{ settings.type_body_font.weight }};
    {% endif %}
    --font-body--scale: {{ settings.type_body_scale | default: 100 | divided_by: 100.0 }};

    {% comment %} ── Layout ── {% endcomment %}
    --page-width:  {{ settings.max_page_width  | default: '1400px' }};
    --page-margin: {{ settings.min_page_margin | default: 20 }}px;

    {% comment %} ── Colors ── {% endcomment %}
    --color-primary:         {{ settings.color_primary        | default: '#1A1A1A' }};
    --color-primary-hover:   {{ settings.color_primary_hover  | default: '#333333' }};
    --color-primary-border:  {{ settings.color_primary_border | default: '#1A1A1A' }};
    --color-secondary:       {{ settings.color_secondary       | default: '#6B6B6B' }};
    --color-secondary-hover: {{ settings.color_secondary_hover | default: '#888888' }};
    --color-background:      {{ settings.color_background | default: '#FFFFFF' }};
    --color-foreground:      {{ settings.color_foreground | default: '#1A1A1A' }};

    {% comment %} ── Buttons ── {% endcomment %}
    --button-border-radius:      {{ settings.button_border_radius      | default: 0 }}px;
    --button-padding-vertical:   {{ settings.button_padding_vertical   | default: 14 }}px;
    --button-padding-horizontal: {{ settings.button_padding_horizontal | default: 28 }}px;

    --button-primary-bg:           {{ settings.color_primary        | default: '#1A1A1A' }};
    --button-primary-color:        {{ settings.color_background      | default: '#FFFFFF' }};
    --button-primary-border:       {{ settings.color_primary_border  | default: '#1A1A1A' }};
    --button-primary-hover-bg:     {{ settings.color_primary_hover   | default: '#333333' }};
    --button-primary-hover-color:  {{ settings.color_background      | default: '#FFFFFF' }};
    --button-primary-hover-border: {{ settings.color_primary_hover   | default: '#333333' }};

    --button-outline-bg:           transparent;
    --button-outline-color:        {{ settings.color_primary       | default: '#1A1A1A' }};
    --button-outline-border:       {{ settings.color_primary_border | default: '#1A1A1A' }};
    --button-outline-hover-bg:     {{ settings.color_primary_hover  | default: '#333333' }};
    --button-outline-hover-color:  {{ settings.color_background     | default: '#FFFFFF' }};
    --button-outline-hover-border: {{ settings.color_primary_hover  | default: '#333333' }};

    {% comment %} ── Inputs ── {% endcomment %}
    --input-border-radius:      {{ settings.input_border_radius | default: 0 }}px;
    --style-border-radius-inputs: {{ settings.input_border_radius | default: 0 }}px;

    {% comment %} ── Badges ── {% endcomment %}
    --badge-sale-bg:       {{ settings.badge_sale_background     | default: '#D9534F' }};
    --badge-sale-color:    {{ settings.badge_sale_color          | default: '#FFFFFF' }};
    --badge-new-bg:        {{ settings.badge_new_background      | default: '#1A1A1A' }};
    --badge-new-color:     {{ settings.badge_new_color           | default: '#FFFFFF' }};
    --badge-sold-out-bg:   {{ settings.badge_sold_out_background | default: '#AAAAAA' }};
    --badge-sold-out-color:{{ settings.badge_sold_out_color      | default: '#FFFFFF' }};
    --badge-border-radius: {{ settings.badge_border_radius       | default: 4 }}px;

    {% comment %} ── Section / block fluid padding ── {% endcomment %}
    --section-padding-fluid:    clamp(66px, 10.42vw, 200px);
    --block-padding-sm-fluid:   clamp(10px,  1.56vw,  30px);
    --block-padding-md-fluid:   clamp(17px,  2.60vw,  50px);

  }

{% endstyle %}
