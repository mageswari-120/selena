--block-pr:
{%- if settings['padding-right'] > 10 -%}
  max(10px, calc({{ settings['padding-right'] }}px * var(--block-padding-scale)));
{%- else -%}
  {{ settings['padding-right'] }}px;
{%- endif -%}
