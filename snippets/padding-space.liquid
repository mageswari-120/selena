--block-pt:
{%- if settings['padding-top'] > 10 -%}
  max(10px, calc({{ settings['padding-top'] }}px * var(--block-padding-scale)));
{%- else -%}
  {{ settings['padding-top'] }}px;
{%- endif -%}


--block-pb:
{%- if settings['padding-bottom'] > 10 -%}
  max(10px, calc({{ settings['padding-bottom'] }}px * var(--block-padding-scale)));
{%- else -%}
  {{ settings['padding-bottom'] }}px;
{%- endif -%}


--block-pl:
{%- if settings['padding-left'] > 10 -%}
  max(10px, calc({{ settings['padding-left'] }}px * var(--block-padding-scale)));
{%- else -%}
