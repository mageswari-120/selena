{%- comment -%}
  snippets/featured-product-placeholder.liquid — Selena Theme
  Empty state when no product is selected in the Featured product section.
{%- endcomment -%}

<div class="featured-product-placeholder" aria-hidden="true">
  <div class="featured-product-placeholder__media">
    {{ 'product-1' | placeholder_svg_tag: 'featured-product-placeholder__svg' }}
  </div>
  <div class="featured-product-placeholder__info">
    <div class="featured-product-placeholder__line featured-product-placeholder__line--short"></div>
    <div class="featured-product-placeholder__line featured-product-placeholder__line--title"></div>
    <div class="featured-product-placeholder__line"></div>
    <div class="featured-product-placeholder__line"></div>
    <div class="featured-product-placeholder__line featured-product-placeholder__line--btn"></div>
    <p class="featured-product-placeholder__hint">{{ 'products.select_product' | t }}</p>
  </div>
</div>

{% stylesheet %}
  .featured-product-placeholder {
    display: grid;
    grid-template-columns: 55% 1fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }
  @media (max-width: 768px) {
    .featured-product-placeholder { grid-template-columns: 1fr; }
  }
  .featured-product-placeholder__media {
    aspect-ratio: 3 / 4;
    background: rgba(0, 0, 0, 0.04);
    border-radius: var(--input-border-radius, 0);
    overflow: hidden;
  }
  .featured-product-placeholder__svg {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.18;
  }
  .featured-product-placeholder__info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.5rem;
  }
  .featured-product-placeholder__line {
    height: 0.85rem;
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.08);
    width: 80%;
  }
  .featured-product-placeholder__line--short { width: 35%; }
  .featured-product-placeholder__line--title { height: 1.5rem; width: 65%; }
  .featured-product-placeholder__line--btn {
    height: 2.75rem;
    width: 100%;
    margin-top: 0.5rem;
    background: rgba(0, 0, 0, 0.12);
  }
  .featured-product-placeholder__hint {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    opacity: 0.55;
    text-align: center;
  }
{% endstylesheet %}
