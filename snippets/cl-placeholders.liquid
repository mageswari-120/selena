{%- comment -%}
  snippets/cl-placeholders.liquid  —  Selena Theme
  ─────────────────────────────────────────────────
  Renders 5 skeleton placeholder cards when the Collection List
  section has no blocks yet (empty state in the theme editor).
  Uses the same grid/carousel track classes as the real cards so
  layout is identical.
{%- endcomment -%}

{%- liquid
  assign placeholder_class = 'cl-card--placeholder card border-0'
  if card_class != blank
    assign placeholder_class = card_class | append: ' cl-card--placeholder'
  endif
-%}

{%- for i in (1..5) -%}
  <div class="{{ placeholder_class }}" aria-hidden="true">
    {{- 'collection-' | append: i | placeholder_svg_tag: 'cl-placeholder__svg' -}}
  </div>
{%- endfor -%}

{% stylesheet %}
.cl-placeholder__svg {
  width: 100%;
  height: 100%;
  display: block;
  opacity: 0.18;
}
{% endstylesheet %}
