{
  "sections": {
    "main": {
      "type": "product",
      "settings": {
        "layout": "container",
        "color_scheme": "scheme-1",
        "padding_top": 60,
        "padding_bottom": 60
      },
      "blocks": {
        "product_media": {
          "type": "product-media",
          "static": true,
          "settings": {
            "media_position": "left",
            "media_width": "55",
            "show_border": false,
            "border_radius": 0,
            "display_type": "carousel",
            "carousel_nav_style": "thumbnails",
            "zoom_type": "none",
            "video_autoplay": false,
            "video_loop": false
          }
        },
        "product_info": {
          "type": "product-info",
          "static": true,
          "blocks": {
            "vendor": {
              "type": "product-vendor",
              "settings": {}
            },
            "title": {
              "type": "product-title",
              "settings": {}
            },
            "price": {
              "type": "product-price",
              "settings": {}
            },
            "separator_1": {
              "type": "product-separator",
              "settings": {}
            },
            "variant_picker": {
              "type": "product-variant-picker",
              "settings": {
                "picker_style": "pill",
                "show_selected_value": true
              }
            },
            "quantity": {
              "type": "product-quantity",
              "settings": {}
            },
            "add_to_cart": {
              "type": "product-add-to-cart",
              "settings": {
                "show_buy_now": true,
                "buy_now_text": "Buy it now",
                "show_dynamic_checkout": false
              }
            },
            "separator_2": {
              "type": "product-separator",
              "settings": {}
            },
            "description": {
              "type": "product-description",
              "settings": {
                "collapsible": false,
                "heading": "Description"
              }
            },
            "share": {
              "type": "product-share",
              "settings": {
                "label": "Share:",
                "show_facebook": true,
                "show_twitter": true,
                "show_pinterest": false
              }
            }
          },
          "block_order": [
            "vendor",
            "title",
            "price",
            "separator_1",
            "variant_picker",
            "quantity",
            "add_to_cart",
            "separator_2",
            "description",
            "share"
          ],
          "settings": {}
        }
      }
    }
  },
  "order": ["main"]
}
