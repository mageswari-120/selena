<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <script>
      document.documentElement.classList.remove('no-js');
      document.documentElement.classList.add('js');
    </script>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <link rel="canonical" href="{{ canonical_url }}">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <meta name="theme-color" content="">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- liquid
      assign needs_fonts_preconnect = false
      unless settings.type_heading_font.system? and settings.type_body_font.system?
        assign needs_fonts_preconnect = true
      endunless
      unless settings.heading_font.system? and settings.body_font.system?
        assign needs_fonts_preconnect = true
      endunless
    -%}
    {%- if needs_fonts_preconnect -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {% render 'meta-tags' %}
    {% render 'root-variable' %}
    {% render 'css-variables' %}

    {{ 'root.css' | asset_url | stylesheet_tag }}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
    {{ 'bootstrap.min.css' | asset_url | stylesheet_tag }}

    {{ content_for_header }}

    {%- unless settings.type_body_font.system? -%}
      {{ settings.type_body_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {%- endunless -%}
    {%- unless settings.type_heading_font.system? -%}
      {{ settings.type_heading_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {%- endunless -%}
    {%- unless settings.body_font.system? -%}
      {{ settings.body_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {%- endunless -%}
    {%- unless settings.heading_font.system? -%}
      {{ settings.heading_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {%- endunless -%}

    <script>
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
  </head>

  <body class="active-template-{{ template }}">
    <a class="skip-to-content-link button visually-hidden btn btn-primary position-absolute start-0 w-auto py-2 px-3" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>

    {%- if settings.cart_type == 'drawer' -%}
      {% section 'cart-drawer' %}
    {%- endif -%}

    <div class="wrapper">
      {% sections 'header-group' %}

      <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
        {{ content_for_layout }}
      </main>

      {% sections 'footer-group' %}
    </div>

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'bootstrap.bundle.min.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'collection-list-carousel.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
