{%- comment -%}
  Block    : wdt-content.liquid
  Type     : wdt-content
  Parent   : sections/testimonial.liquid (fixed slot via content_for 'block')
  Children : wdt-card × N  (merchant adds/reorders via content_for 'blocks')
{%- endcomment -%}

{%- liquid
  assign layout_type  = block.settings.layout_type
  assign col_gap      = block.settings.column_gap
  assign row_gap      = block.settings.row_gap
  assign cols_dt      = block.settings.columns_desktop
  assign cols_mb      = block.settings.columns_mobile
  assign autoplay     = block.settings.autoplay_speed
  assign loop         = block.settings.carousel_loop
  assign nav_style    = block.settings.nav_style
  assign slides_dt    = block.settings.slides_desktop
  assign carousel_id  = 'wdt-carousel-' | append: block.id
  assign border_alpha = block.settings.border_opacity | divided_by: 100.0
  assign nav_border_alpha = block.settings.nav_border_opacity | divided_by: 100.0

  assign content_scheme_class = ''
  unless block.settings.inherit_color_scheme
    assign content_scheme_class = 'color-' | append: block.settings.content_color_scheme
  endunless

  assign nav_scheme_class = ''
  unless block.settings.nav_inherit_color
    assign nav_scheme_class = 'color-' | append: block.settings.nav_color_scheme
  endunless
-%}

<div
  class="wdt-testimonial__content {{ content_scheme_class }}"
  {{ block.shopify_attributes }}
  style="
    --wdt-col-gap: {{ col_gap }}px;
    --wdt-row-gap: {{ row_gap }}px;
    --wdt-cols-dt: {{ cols_dt }};
    --wdt-cols-mb: {{ cols_mb }};
    --wdt-slides-dt: {{ slides_dt }};
    --wdt-border-radius: {{ block.settings.border_radius }}px;
    --wdt-nav-radius: {{ block.settings.nav_border_radius }}px;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    {%- if block.settings.border_style == 'solid' -%}
      border: {{ block.settings.border_width }}px solid rgba(0,0,0,{{ border_alpha }});
      border-radius: var(--wdt-border-radius);
    {%- endif -%}
    {%- if block.settings.nav_border_style == 'solid' -%}
      --wdt-nav-border: {{ block.settings.nav_border_width }}px solid rgba(0,0,0,{{ nav_border_alpha }});
    {%- endif -%}
  "
  data-wdt-content
  data-layout="{{ layout_type }}"
  data-slides-desktop="{{ slides_dt }}"
>
  {%- liquid
    assign is_carousel = false
    if layout_type == 'carousel'
      assign is_carousel = true
    endif
    assign track_class = 'wdt-content__grid row'
    if is_carousel
      assign track_class = 'carousel-inner wdt-content__track'
    endif
  -%}

  {%- if is_carousel -%}
    <div
      id="{{ carousel_id }}"
      class="wdt-content__carousel carousel slide {{ nav_scheme_class }}"
      data-bs-ride="{% if autoplay > 0 %}carousel{% else %}false{% endif %}"
      {% if autoplay > 0 %}data-bs-interval="{{ autoplay | times: 1000 }}"{% endif %}
      data-bs-wrap="{{ loop }}"
      data-wdt-carousel
    >
  {%- endif -%}

    <div class="{{ track_class }}">
      {% content_for 'blocks' %}
    </div>

    {%- if is_carousel -%}
      {%- if nav_style == 'navigation' or nav_style == 'both' -%}
        <button
          class="wdt-content__nav wdt-content__nav--prev carousel-control-prev"
          type="button"
          data-bs-target="#{{ carousel_id }}"
          data-bs-slide="prev"
          aria-label="Previous"
        >
          <span class="wdt-content__nav-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </span>
        </button>
        <button
          class="wdt-content__nav wdt-content__nav--next carousel-control-next"
          type="button"
          data-bs-target="#{{ carousel_id }}"
          data-bs-slide="next"
          aria-label="Next"
        >
          <span class="wdt-content__nav-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </span>
        </button>
      {%- endif -%}

      {%- if nav_style == 'pagination' or nav_style == 'both' -%}
        <div class="wdt-content__dots carousel-indicators" data-wdt-dots></div>
      {%- endif -%}
    </div>
  {%- endif -%}

</div>

{% stylesheet %}

.wdt-testimonial__content {
  position: relative;
}

.wdt-content__grid {
  --bs-gutter-x: var(--wdt-col-gap, 20px);
  --bs-gutter-y: var(--wdt-row-gap, 20px);
}

.wdt-content__carousel { position: relative; }
.wdt-content__track    { width: 100%; }

.wdt-content__nav {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: var(--wdt-nav-radius, 50%);
  background: var(--color-background, #fff);
  border: var(--wdt-nav-border, 1px solid rgba(0,0,0,.12));
  color: var(--color-foreground, #1a1a1a);
  opacity: 1;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  transition: background .2s, color .2s, border-color .2s;
  padding: 0;
  cursor: pointer;
}
.wdt-content__nav--prev { left: -22px; }
.wdt-content__nav--next { right: -22px; }
.wdt-content__nav:hover {
  background: var(--color-primary, #1a1a1a);
  color: var(--color-background, #fff);
  border-color: var(--color-primary, #1a1a1a);
}
.wdt-content__nav.carousel-control-prev,
.wdt-content__nav.carousel-control-next {
  width: 44px;
  opacity: 1;
}
.wdt-content__nav-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.wdt-content__dots {
  position: static;
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 1.25rem;
  padding: 0;
}
.wdt-content__dots .carousel-indicator-btn {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(0,0,0,.2);
  border: none;
  padding: 0;
  cursor: pointer;
  transition: background .2s, transform .2s;
}
.wdt-content__dots .carousel-indicator-btn.active,
.wdt-content__dots .carousel-indicator-btn:hover {
  background: var(--color-primary, #1a1a1a);
  transform: scale(1.25);
}

.wdt-content__carousel[data-slides-desktop='2'] .carousel-item.active,
.wdt-content__carousel[data-slides-desktop='2'] .carousel-item-next,
.wdt-content__carousel[data-slides-desktop='2'] .carousel-item-prev {
  display: flex;
  gap: var(--wdt-col-gap, 20px);
}
.wdt-content__carousel[data-slides-desktop='2'] .carousel-item .wdt-content__grid-item,
.wdt-content__carousel[data-slides-desktop='2'] .carousel-item .wdt-content__slide {
  flex: 1 1 50%;
}

@media (max-width: 767.98px) {
  .wdt-content__nav--prev { left: 0; }
  .wdt-content__nav--next { right: 0; }
}

{% endstylesheet %}

{% javascript %}
(function () {
  function initContent(root) {
    var carousel = root.querySelector('[data-wdt-carousel]');
    if (!carousel) return;

    var inner = carousel.querySelector('.carousel-inner');
    if (!inner) return;

    var slidesDesktop = parseInt(root.dataset.slidesDesktop || '1', 10);
    var cards = inner.querySelectorAll(':scope > .wdt-content__slide, :scope > .wdt-content__grid-item');
    if (!cards.length) return;

    if (slidesDesktop > 1) {
      inner.innerHTML = '';
      for (var i = 0; i < cards.length; i += slidesDesktop) {
        var item = document.createElement('div');
        item.className = 'carousel-item' + (i === 0 ? ' active' : '');
        for (var j = 0; j < slidesDesktop && i + j < cards.length; j += 1) {
          item.appendChild(cards[i + j]);
        }
        inner.appendChild(item);
      }
    } else {
      cards.forEach(function (card, index) {
        if (!card.classList.contains('carousel-item')) {
          card.classList.add('carousel-item');
        }
        if (index === 0) {
          card.classList.add('active');
        }
      });
    }

    var dotsWrap = carousel.querySelector('[data-wdt-dots]');
    if (dotsWrap) {
      dotsWrap.innerHTML = '';
      var items = inner.querySelectorAll('.carousel-item');
      items.forEach(function (_, index) {
        var button = document.createElement('button');
        button.type = 'button';
        button.className = 'carousel-indicator-btn' + (index === 0 ? ' active' : '');
        button.setAttribute('data-bs-target', '#' + carousel.id);
        button.setAttribute('data-bs-slide-to', String(index));
        button.setAttribute('aria-label', 'Slide ' + (index + 1));
        if (index === 0) {
          button.setAttribute('aria-current', 'true');
        }
        dotsWrap.appendChild(button);
      });
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      carousel.removeAttribute('data-bs-ride');
      carousel.setAttribute('data-bs-interval', 'false');
    }
  }

  function initAll(scope) {
    (scope || document).querySelectorAll('[data-wdt-content]').forEach(initContent);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { initAll(); });
  } else {
    initAll();
  }

  document.addEventListener('shopify:section:load', function (event) {
    initAll(event.target);
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "Testimonial Content",
  "blocks": [
    { "type": "wdt-card" }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "Type",
      "options": [
        { "value": "grid",     "label": "Grid" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "carousel"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column Gap",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "row_gap",
      "label": "Row Gap",
      "info": "Applies when Type = Grid",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 20,
      "visible_if": "{{ block.settings.layout_type == 'grid' }}"
    },
    {
      "type": "header",
      "content": "Columns"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3",
      "visible_if": "{{ block.settings.layout_type == 'grid' }}"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Mobile Columns",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1",
      "visible_if": "{{ block.settings.layout_type == 'grid' }}"
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Change Slide Every (seconds)",
      "info": "Set to 0 to disable autoplay",
      "min": 0, "max": 5, "step": 1, "unit": "s",
      "default": 0,
      "visible_if": "{{ block.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "checkbox",
      "id": "carousel_loop",
      "label": "Loop",
      "default": true,
      "visible_if": "{{ block.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "select",
      "id": "slides_desktop",
      "label": "Slides Visible on Desktop",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1",
      "visible_if": "{{ block.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "select",
      "id": "nav_style",
      "label": "Navigation Style",
      "options": [
        { "value": "navigation", "label": "Navigation (Arrows)" },
        { "value": "pagination", "label": "Pagination (Dots)" },
        { "value": "both",       "label": "Both" },
        { "value": "none",       "label": "None" }
      ],
      "default": "navigation",
      "visible_if": "{{ block.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "select",
      "id": "nav_border_style",
      "label": "Navigation Border Style",
      "options": [
        { "value": "none",  "label": "None" },
        { "value": "solid", "label": "Solid" }
      ],
      "default": "none",
      "visible_if": "{{ block.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "range",
      "id": "nav_border_width",
      "label": "Navigation Border Width",
      "min": 1, "max": 5, "step": 1, "unit": "px",
      "default": 1,
      "visible_if": "{{ block.settings.nav_border_style == 'solid' }}"
    },
    {
      "type": "range",
      "id": "nav_border_opacity",
      "label": "Navigation Border Opacity",
      "min": 0, "max": 100, "step": 5, "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.nav_border_style == 'solid' }}"
    },
    {
      "type": "range",
      "id": "nav_border_radius",
      "label": "Navigation Border Radius",
      "min": 0, "max": 30, "step": 1, "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "checkbox",
      "id": "nav_inherit_color",
      "label": "Navigation Inherit Color",
      "default": true,
      "visible_if": "{{ block.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "color_scheme",
      "id": "nav_color_scheme",
      "label": "Navigation Color Scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.nav_inherit_color == false }}"
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border Style",
      "options": [
        { "value": "none",  "label": "None" },
        { "value": "solid", "label": "Solid" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border Width",
      "min": 1, "max": 5, "step": 1, "unit": "px",
      "default": 1,
      "visible_if": "{{ block.settings.border_style == 'solid' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "label": "Border Opacity",
      "min": 0, "max": 100, "step": 5, "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.border_style == 'solid' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0, "max": 30, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "Inherit Color Scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "content_color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding Left",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding Right",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
