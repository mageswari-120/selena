{% doc %}
  Collection image block.
  Renders the featured image of the closest collection (passed down from the
  parent collection-card via {% content_for 'block', ... closest.collection %}).
  The visual shape (oval / arch / circle …) is driven by the parent card's
  `image_shape` class — this block only owns the ratio, border and overlay.

  @example 
  {% content_for 'block', type: 'collection-image', id: 'collection-image' %}
{% enddoc %}

{%- liquid
  assign s = block.settings
  assign collection = closest.collection
  assign image = s.image | default: collection.featured_image
  assign border_alpha = s.border_opacity | divided_by: 100.0
-%}

<div
  class="cl-collection-image cl-collection-image--ratio-{{ s.image_ratio }}{% if s.media_overlay %} cl-collection-image--has-overlay{% endif %}"
  style="
    --cl-img-radius: {{ s.border_radius }}px;
    --cl-img-overlay-opacity: {{ s.overlay | times: 0.1 }};
    --cl-arch-h: {{ s.arch_height }}px;
    --cl-arch-w: {{ s.arch_width }}px;
    {%- if s.border_style != 'none' %}--cl-img-border: {{ s.border_width }}px solid rgba(0,0,0,{{ border_alpha }});{% endif %}
  "
  {{ block.shopify_attributes }}
>
  <a
    class="cl-collection-image__media"
    href="{{ collection.url | default: '#' }}"
    {% if image == blank %}aria-hidden="true" tabindex="-1"{% endif %}
  >
    {%- if image != blank -%}
      {{
        image
        | image_url: width: 1066
        | image_tag:
          loading: 'lazy',
          widths: '165,360,535,720,940,1066',
          sizes: '(min-width: 990px) 20vw, (min-width: 750px) 33vw, 45vw',
          class: 'cl-collection-image__img',
          alt: image.alt | default: collection.title | escape
      }}
    {%- else -%}
      {{ 'collection-1' | placeholder_svg_tag: 'cl-collection-image__placeholder' }}
    {%- endif -%}

    {%- if s.media_overlay -%}
      <span class="cl-collection-image__overlay" aria-hidden="true"></span>
    {%- endif -%}
  </a>
</div>

{% stylesheet %}
  .cl-collection-image {
    width: 100%;
  }

  .cl-collection-image__media {
    position: relative;
    display: block;
    overflow: hidden;
    width: 100%;
    border-radius: var(--cl-img-radius, 0);
    border: var(--cl-img-border, none);
    background: rgba(0, 0, 0, 0.05);
  }

  /* Ratios — overridden by the card's shape classes when set */
  .cl-collection-image--ratio-square .cl-collection-image__media { aspect-ratio: 1 / 1; }
  .cl-collection-image--ratio-landscape .cl-collection-image__media { aspect-ratio: 4 / 3; }
  .cl-collection-image--ratio-portrait .cl-collection-image__media { aspect-ratio: 3 / 4; }
  .cl-collection-image--ratio-adapt .cl-collection-image__media { aspect-ratio: auto; }

  .cl-collection-image__img,
  .cl-collection-image__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--cl-img-position, center);
    transition: transform 0.5s ease;
  }

  .cl-collection-card:hover .cl-collection-image__img { transform: scale(1.05); }

  .cl-collection-image__overlay {
    position: absolute;
    inset: 0;
    background: #000;
    opacity: var(--cl-img-overlay-opacity, 0.2);
    pointer-events: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Custom image",
      "info": "Optional. Overrides the collection's featured image — use for a custom (non-collection) tile."
    },
    {
      "type": "checkbox",
      "id": "media_overlay",
      "label": "Media overlay",
      "default": false,
      "info": "Adds a dark scrim — useful when text sits on top of the image."
    },
    {
      "type": "range",
      "id": "overlay",
      "label": "Overlay intensity",
      "min": 0,
      "max": 9,
      "step": 1,
      "default": 2,
      "visible_if": "{{ block.settings.media_overlay }}"
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border style",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "solid", "label": "Solid" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 1,
      "visible_if": "{{ block.settings.border_style != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "label": "Border opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.border_style != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square", "label": "Square" },
        { "value": "landscape", "label": "Landscape" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "adapt", "label": "Adapt" }
      ],
      "default": "adapt"
    },
    {
      "type": "range",
      "id": "arch_height",
      "label": "Arch height",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 300,
      "info": "Used when the card's image shape is Arch or Rounded arch."
    },
    {
      "type": "range",
      "id": "arch_width",
      "label": "Arch width",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 250,
      "info": "Used when the card's image shape is Arch or Rounded arch."
    }
  ],
  "presets": [{ "name": "Collection image" }]
}
{% endschema %}

