{% doc %}
  blocks/collection-card.liquid  —  Selena Theme  (OS 3.0)
  ──────────────────────────────────────────────────────────
  Static wrapper block for a single collection tile.

  Rendered once per collection by the Collection List section:
      {% content_for 'block', type: 'collection-card', id: 'cl-card',
         closest.collection: col, card_class: …, card_style: … %}

  Architecture (static + dynamic per Shopify guidelines):
    • collection-image  → static, fixed (always first)
    • collection-title  → static, fixed (always second)
    • content_for 'blocks' → DYNAMIC children the merchant can add,
        remove and reorder: collection-description, collection-button,
        collection-text.

  Reads:  closest.collection  (passed by the section)
  Params: card_class, card_style  (computed appearance, owned by the
          section so all cards share one look)
{% enddoc %}

{%- liquid
  assign collection = closest.collection
-%}

<div
  class="{{ card_class | default: 'cl-collection-card' }}"
  role="listitem"
  style="{{ card_style }}"
  {{ block.shopify_attributes }}
>
  <div class="cl-card__inner">
    {%- comment -%} Static, fixed slots — always present, not reorderable {%- endcomment -%}
    {% content_for 'block', type: 'collection-image', id: 'cl-img', closest.collection: collection %}

    <div class="cl-card__content">
      {% content_for 'block', type: 'collection-title', id: 'cl-title', closest.collection: collection %}

      {%- comment -%}
        Dynamic children — description, button, text.
        Merchant adds / removes / reorders these in the theme editor.
      {%- endcomment -%}
      {% content_for 'blocks', closest.collection: collection %}
    </div>
  </div>
</div>

{% stylesheet %}
/* ─────────────────────────────────────────────
   Collection Card — tile, overlay, image shapes
   (moved here from the section so it lives with
   the markup it styles; theme stylesheet blocks
   are merged theme-wide so selectors still apply)
───────────────────────────────────────────── */

.cl-collection-card {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100%;
  border-radius: var(--cl-card-radius, 0);
  overflow: hidden;
  background: var(--color-background, transparent);
  color: inherit;
  transition: box-shadow 0.25s ease;
}
.cl-collection-card:hover { box-shadow: 0 12px 32px rgba(0,0,0,0.10); }

.cl-card__inner {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
  padding: var(--cl-pad-t,0) var(--cl-pad-r,0) var(--cl-pad-b,0) var(--cl-pad-l,0);
}
.cl-card__content {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

/* Content alignment */
.cl-align-left   .cl-card__content { align-items: flex-start; text-align: left; }
.cl-align-center .cl-card__content { align-items: center;     text-align: center; }
.cl-align-right  .cl-card__content { align-items: flex-end;   text-align: right; }

/* ── On-image overlay ──
   Image stays in normal flow inside a single grid cell, so the card
   height follows the chosen image ratio (no more fixed min-height).
   The content shares that same cell and is layered on top. */
.cl-overlay-on-image .cl-card__inner {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
}
.cl-overlay-on-image .cl-collection-image,
.cl-overlay-on-image .cl-card__content {
  grid-area: 1 / 1 / 2 / 2;
}
.cl-overlay-on-image .cl-collection-image { z-index: 0; align-self: stretch; }
.cl-overlay-on-image .cl-collection-image__media,
.cl-overlay-on-image .cl-collection-image__img { border-radius: 0; }
.cl-overlay-on-image .cl-card__content {
  z-index: 1;
  padding: 1rem;
}
.cl-overlay-on-image.cl-pos-top    .cl-card__content { justify-content: flex-start; }
.cl-overlay-on-image.cl-pos-center .cl-card__content { justify-content: center; }
.cl-overlay-on-image.cl-pos-bottom .cl-card__content { justify-content: flex-end; }

/* Below-image overlay: default flow (image, then content) */
.cl-overlay-below-image .cl-card__inner { justify-content: flex-start; }

/* ── Image shapes (driven by CSS vars set in card_style on this root) ── */
.cl-shape-circle .cl-collection-image__media { border-radius: 50%; aspect-ratio: 1/1; }
.cl-shape-oval   .cl-collection-image__media { border-radius: 50%/42%; aspect-ratio: 4/5; }
.cl-shape-pill   .cl-collection-image__media { border-radius: 999px; aspect-ratio: 3/4; }
.cl-shape-rounded-rectangle .cl-collection-image__media { border-radius: 16px; }
.cl-shape-custom-radius .cl-collection-image__media { border-radius: var(--cl-custom-radius,16px); }
.cl-shape-arch .cl-collection-image__media {
  height: var(--cl-arch-h,300px); aspect-ratio: auto;
  border-radius: 50% 50% 0 0 / 65% 65% 0 0;
}
.cl-shape-rounded-arch .cl-collection-image__media {
  height: var(--cl-arch-h,300px); aspect-ratio: auto;
  border-radius: calc(var(--cl-arch-w,250px)/2) calc(var(--cl-arch-w,250px)/2) 0 0;
}
.cl-shape-circle .cl-collection-image,
.cl-shape-oval   .cl-collection-image,
.cl-shape-pill   .cl-collection-image { margin-inline: auto; }

@media (prefers-reduced-motion: reduce) { .cl-collection-card { transition: none; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection card",
  "blocks": [
    { "type": "collection-description" },
    { "type": "collection-button" },
    { "type": "collection-text" }
  ]
}
{% endschema %}
