{% doc %}
  blocks/collection-card.liquid  —  Selena Theme  (OS 3.0)
  ──────────────────────────────────────────────────────────
  Static wrapper block for a single collection tile.

  Rendered once per collection by the Collection List section:
      {% content_for 'block', type: 'collection-card', id: 'cl-card',
         closest.collection: col, is_carousel: is_carousel %}

  Architecture (static + dynamic per Shopify guidelines):
    • collection-image  → static, fixed (always first)
    • collection-title  → static, fixed (always second)
    • content_for 'blocks' → DYNAMIC children the merchant can add,
        remove and reorder: collection-description, collection-button,
        collection-text.

  Reads:  closest.collection  (passed by the section)
  Params: is_carousel  (optional — adds swiper-slide when true)

  CSS variables: settings → {% render 'cl-card-style' %} / {% render 'spacing-style' %}
  on inline style attributes; {% stylesheet %} consumes var(--cl-*).
{% enddoc %}

{%- liquid
  assign collection = closest.collection
  assign bs = block.settings

  assign card_classes = 'cl-collection-card card h-100 d-flex flex-column border-0 bg-transparent'
  assign card_classes = card_classes | append: ' cl-shape-' | append: bs.card_image_shape
  if is_carousel
    assign card_classes = card_classes | append: ' swiper-slide'
  endif

  assign bs_align = 'center'
  if bs.card_content_alignment == 'left'
    assign bs_align = 'start'
  elsif bs.card_content_alignment == 'right'
    assign bs_align = 'end'
  endif

  assign text_align = 'text-' | append: bs_align
  assign horizontal_alignment = 'align-items-' | append: bs_align

  assign inner_classes = 'cl-card__inner position-relative'
  assign content_classes = 'cl-card__content d-flex flex-column gap-2 p-3 w-100'
  assign content_classes = content_classes | append: ' ' | append: text_align | append: ' ' | append: horizontal_alignment

  if bs.card_overlay_style == 'on-image'
    assign bs_justify = 'center'
    if bs.card_content_position == 'top'
      assign bs_justify = 'start'
    elsif bs.card_content_position == 'bottom'
      assign bs_justify = 'end'
    endif
    assign vertical_position = 'justify-content-' | append: bs_justify
    assign content_classes = content_classes | append: ' position-absolute top-0 start-0 h-100 z-1 pe-none ' | append: vertical_position
  else
    assign inner_classes = inner_classes | append: ' d-flex flex-column gap-2 flex-fill'
  endif
-%}

<div
  class="{{ card_classes }}"
  role="listitem"
  style="{% render 'cl-card-style', settings: bs %}"
  {{ block.shopify_attributes }}
>
  <div
    class="{{ inner_classes }}"
    style="{% render 'spacing-style', prefix: '--cl-pad', mode: 'padding' %}"
  >
    {% content_for 'block', type: 'collection-image', id: 'cl-img', closest.collection: collection %}

    <div class="{{ content_classes }}">
      {% content_for 'block', type: 'collection-title', id: 'cl-title', closest.collection: collection %}
      {% content_for 'blocks', closest.collection: collection %}
    </div>
  </div>
</div>

{% stylesheet %}
.cl-collection-card {
  position: relative;
  border-radius: var(--cl-card-radius, 0);
  overflow: hidden;
  color: inherit;
  transition: box-shadow 0.25s ease;
}
.cl-collection-card:hover { box-shadow: 0 12px 32px rgba(0,0,0,0.10); }

.cl-card__content.pe-none > * { pointer-events: auto; }

.cl-shape-circle .cl-collection-image__media { border-radius: 50%; aspect-ratio: 1/1; }
.cl-shape-oval   .cl-collection-image__media { border-radius: 50%/42%; aspect-ratio: 4/5; }
.cl-shape-pill   .cl-collection-image__media { border-radius: 999px; aspect-ratio: 3/4; }
.cl-shape-rounded-rectangle .cl-collection-image__media { border-radius: 16px; }
.cl-shape-custom-radius .cl-collection-image__media { border-radius: var(--cl-custom-radius,16px); }
.cl-shape-arch .cl-collection-image__media {
  height: var(--cl-arch-h,300px); aspect-ratio: auto;
  border-radius: 50% 50% 0 0 / 65% 65% 0 0;
}
.cl-shape-rounded-arch .cl-collection-image__media {
  height: var(--cl-arch-h,300px); aspect-ratio: auto;
  border-radius: calc(var(--cl-arch-w,250px)/2) calc(var(--cl-arch-w,250px)/2) 0 0;
}
.cl-shape-circle .cl-collection-image,
.cl-shape-oval   .cl-collection-image,
.cl-shape-pill   .cl-collection-image { margin-inline: auto; }

@media (prefers-reduced-motion: reduce) { .cl-collection-card { transition: none; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection card",
  "tag": null,
  "blocks": [
    { "type": "collection-description" },
    { "type": "collection-button" },
    { "type": "collection-text" }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Card — Image shape"
    },
    {
      "type": "select",
      "id": "card_image_shape",
      "label": "Image shape",
      "options": [
        { "value": "default",           "label": "Default" },
        { "value": "arch",              "label": "Arch" },
        { "value": "rounded-arch",      "label": "Rounded arch" },
        { "value": "oval",              "label": "Oval" },
        { "value": "circle",            "label": "Circle" },
        { "value": "pill",              "label": "Pill" },
        { "value": "rounded-rectangle", "label": "Rounded rectangle" },
        { "value": "custom-radius",     "label": "Custom radius" }
      ],
      "default": "default"
    },
    {
      "type": "range",
      "id": "card_custom_radius",
      "label": "Custom radius",
      "min": 0, "max": 50, "step": 1, "unit": "px",
      "default": 16,
      "visible_if": "{{ block.settings.card_image_shape == 'custom-radius' }}"
    },
    {
      "type": "range",
      "id": "card_arch_height",
      "label": "Arch height",
      "min": 100, "max": 500, "step": 10, "unit": "px",
      "default": 300,
      "visible_if": "{{ block.settings.card_image_shape == 'arch' or block.settings.card_image_shape == 'rounded-arch' }}"
    },
    {
      "type": "range",
      "id": "card_arch_width",
      "label": "Arch width",
      "min": 100, "max": 500, "step": 10, "unit": "px",
      "default": 250,
      "visible_if": "{{ block.settings.card_image_shape == 'rounded-arch' }}"
    },
    {
      "type": "select",
      "id": "card_image_position",
      "label": "Image position",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Card — Content"
    },
    {
      "type": "select",
      "id": "card_overlay_style",
      "label": "Overlay style",
      "options": [
        { "value": "on-image",    "label": "On image" },
        { "value": "below-image", "label": "Below image" }
      ],
      "default": "below-image"
    },
    {
      "type": "select",
      "id": "card_content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "card_content_position",
      "label": "Content position",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "bottom",
      "visible_if": "{{ block.settings.card_overlay_style == 'on-image' }}"
    },
    {
      "type": "header",
      "content": "Card — Border"
    },
    {
      "type": "select",
      "id": "card_border_style",
      "label": "Border style",
      "options": [
        { "value": "none",  "label": "None" },
        { "value": "solid", "label": "Solid" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Border width",
      "min": 1, "max": 5, "step": 1, "unit": "px",
      "default": 1,
      "visible_if": "{{ block.settings.card_border_style != 'none' }}"
    },
    {
      "type": "range",
      "id": "card_border_opacity",
      "label": "Border opacity",
      "min": 0, "max": 100, "step": 1, "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.card_border_style != 'none' }}"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Border radius",
      "min": 0, "max": 30, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Card — Padding"
    },
    {
      "type": "range",
      "id": "card_padding_top",
      "label": "Padding top",
      "min": 0, "max": 50, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 50, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_padding_left",
      "label": "Padding left",
      "min": 0, "max": 50, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_padding_right",
      "label": "Padding right",
      "min": 0, "max": 50, "step": 1, "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
