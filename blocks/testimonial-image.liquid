{% doc %}
  Renders the featured image inside a testimonial card.

  @example
  {% content_for 'block', type: 'testimonial-image', id: 'image' %}
{% enddoc %}

{%- if block.settings.image != blank -%}
  <div
    class="wdt-card__image-wrap"
    {{ block.shopify_attributes }}
    style="
      padding-top: {{ block.settings.padding_top }}px;
      padding-bottom: {{ block.settings.padding_bottom }}px;
      padding-left: {{ block.settings.padding_left }}px;
      padding-right: {{ block.settings.padding_right }}px;
    "
  >
    {{- block.settings.image
      | image_url: width: 800
      | image_tag:
        class: 'wdt-card__image',
        widths: '200,400,600,800',
        sizes: '(max-width: 576px) 100vw, 33vw',
        loading: 'lazy',
        alt: block.settings.image.alt | escape
    -}}
  </div>
{%- endif -%}

{% stylesheet %}
.wdt-card__image-wrap { display: block; }
.wdt-card__image {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.testimonial_image.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "header",
      "content": "t:labels.padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.top_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.bottom_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "t:labels.left_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "t:labels.right_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:blocks.testimonial_image.preset_name"
    }
  ]
}
{% endschema %}
