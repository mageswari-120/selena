{% doc %}
  blocks/testimonial-client.liquid  —  Selena Theme  (OS 3.0)
  Parent: blocks/testimonial-card.liquid
{% enddoc %}

{%- liquid
  assign img_pos    = block.settings.image_position
  assign aspect     = block.settings.aspect_ratio
  assign client_gap = block.settings.client_gap
-%}

<div
  class="wdt-card__client wdt-card__client--{{ img_pos }}"
  {{ block.shopify_attributes }}
  style="
    --wdt-client-gap: {{ client_gap }}px;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
  "
>
  {%- if block.settings.image != blank -%}
    <div class="wdt-card__avatar wdt-card__avatar--{{ aspect }}">
      {{- block.settings.image
        | image_url: width: 200
        | image_tag:
          class: 'wdt-card__avatar-img',
          widths: '80,100,120,160,200',
          sizes: '80px',
          loading: 'lazy',
          alt: block.settings.name | escape
      -}}
    </div>
  {%- else -%}
    <div class="wdt-card__avatar wdt-card__avatar--{{ aspect }} wdt-card__avatar--placeholder">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.582-7 8-7s8 3 8 7"/>
      </svg>
    </div>
  {%- endif -%}

  <div class="wdt-card__client-meta">
    {%- if block.settings.name != blank -%}
      <p class="wdt-card__client-name">{{ block.settings.name | escape }}</p>
    {%- endif -%}
    {%- if block.settings.profession != blank -%}
      <p class="wdt-card__client-prof">{{ block.settings.profession | escape }}</p>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
.wdt-card__client {
  display: flex;
  align-items: center;
  gap: var(--wdt-client-gap, 10px);
  margin-top: auto;
}
.wdt-card__client--top  { flex-direction: column; align-items: inherit; }
.wdt-card__client--left { flex-direction: row; align-items: center; }
.wdt-card.text-center .wdt-card__client--top { align-items: center; }
.wdt-card.text-end    .wdt-card__client--top { align-items: flex-end; }
.wdt-card__avatar {
  flex-shrink: 0;
  width: 56px;
  height: 56px;
  overflow: hidden;
  background: rgba(0,0,0,.06);
  display: flex;
  align-items: center;
  justify-content: center;
}
.wdt-card__avatar--square   { border-radius: 0; aspect-ratio: 1/1; }
.wdt-card__avatar--portrait { border-radius: 0; width: 48px; height: 64px; }
.wdt-card__avatar--adapt    { border-radius: 0; width: auto; height: auto; max-width: 80px; }
.wdt-card__avatar--circle   { border-radius: 50%; }
.wdt-card__avatar-img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
.wdt-card__avatar--placeholder svg {
  width: 60%; height: 60%; opacity: 0.4;
}
.wdt-card__client-meta { display: flex; flex-direction: column; gap: 2px; }
.wdt-card__client-name {
  font-size: 0.875rem;
  font-weight: 700;
  margin: 0;
  color: var(--color-foreground, #1a1a1a);
  line-height: 1.3;
}
.wdt-card__client-prof {
  font-size: 0.75rem;
  margin: 0;
  opacity: 0.55;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  line-height: 1.3;
}
@media (max-width: 575.98px) {
  .wdt-card__client--left { flex-direction: column; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.testimonial_client.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:blocks.testimonial_client.client_image"
    },
    {
      "type": "text",
      "id": "name",
      "label": "t:blocks.testimonial_client.name_label",
      "default": "John"
    },
    {
      "type": "text",
      "id": "profession",
      "label": "t:blocks.testimonial_client.profession",
      "default": "Director"
    },
    {
      "type": "header",
      "content": "t:blocks.testimonial_client.headers.image_options"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:labels.image_position",
      "options": [
        { "value": "top",  "label": "t:options.client_image_position.top" },
        { "value": "left", "label": "t:options.client_image_position.left" }
      ],
      "default": "top"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "t:labels.image_ratio",
      "options": [
        { "value": "square",   "label": "t:options.image_ratio.square" },
        { "value": "portrait", "label": "t:options.image_ratio.portrait" },
        { "value": "adapt",    "label": "t:options.image_ratio.adapt" },
        { "value": "circle",   "label": "t:options.image_shape.circle" }
      ],
      "default": "circle"
    },
    {
      "type": "range",
      "id": "client_gap",
      "label": "t:blocks.testimonial_client.client_gap",
      "min": 0, "max": 30, "step": 2, "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "t:labels.padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.top_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.bottom_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "t:labels.left_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "t:labels.right_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:blocks.testimonial_client.preset_name"
    }
  ]
}
{% endschema %}
