{% doc %}
  blocks/testimonial-button.liquid  —  Selena Theme  (OS 3.0)
  Parent: blocks/testimonial-header.liquid
{% enddoc %}

{%- if block.settings.label != blank -%}
  <div
    class="wdt-hdr__btn-wrap"
    {{ block.shopify_attributes }}
    style="
      padding-top: {{ block.settings.padding_top }}px;
      padding-bottom: {{ block.settings.padding_bottom }}px;
    "
  >
    <a
      href="{{ block.settings.url | default: '#' }}"
      class="wdt-hdr__btn btn btn-{{ block.settings.style }}"
      {% if block.settings.open_new_tab %}
        target="_blank"
        rel="noopener noreferrer"
      {% endif %}
    >
      {{- block.settings.label | escape -}}
    </a>
  </div>
{%- endif -%}

{% stylesheet %}
.wdt-hdr__btn-wrap {
  display: flex;
  justify-content: inherit;
}
.wdt-hdr__btn.btn-link {
  padding-left: 0;
  padding-right: 0;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.testimonial_button.name",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:labels.button_label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "url",
      "label": "t:labels.button_link"
    },
    {
      "type": "select",
      "id": "style",
      "label": "t:labels.button_style",
      "options": [
        { "value": "primary", "label": "t:options.button_style.primary" },
        { "value": "outline-secondary", "label": "t:options.button_style.secondary" },
        { "value": "link", "label": "t:options.button_style.link" }
      ],
      "default": "primary"
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "t:blocks.testimonial_button.open_new_tab",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.top_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.bottom_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:blocks.testimonial_button.preset_name"
    }
  ]
}
{% endschema %}
