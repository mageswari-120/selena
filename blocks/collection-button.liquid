{% doc %}
  blocks/collection-button.liquid  —  Selena Theme  (OS 3.0)
  ───────────────────────────────────────────────────────────
  CTA button for a collection card.  Links to the closest
  collection's URL by default; merchant can override with a
  custom URL.

  Supports four button styles:
    primary   — Bootstrap btn-primary
    secondary — Bootstrap btn-outline-secondary
    link      — Bootstrap btn-link
    arrow     — label + directional arrow icon (four icon styles)

  Reads:  closest.collection  (passed by the parent card)
{% enddoc %}

{%- liquid
  assign s          = block.settings
  assign collection = closest.collection

  assign link = s.button_link
  if link == blank
    assign link = collection.url
  endif
  if link == blank
    assign link = '#'
  endif

  assign label = s.button_label | default: 'Shop Now'

  assign wrap_class = 'cl-collection-button d-inline-flex'
  if s.pin_bottom
    assign wrap_class = wrap_class | append: ' mt-auto'
  endif
  if s.align != 'auto'
    assign btn_align = 'center'
    if s.align == 'left'
      assign btn_align = 'start'
    elsif s.align == 'right'
      assign btn_align = 'end'
    endif
    assign wrap_class = wrap_class | append: ' align-self-' | append: btn_align
  endif

  assign btn_class = 'btn btn-primary'
  if s.button_style == 'secondary'
    assign btn_class = 'btn btn-outline-secondary'
  elsif s.button_style == 'link'
    assign btn_class = 'btn btn-link'
  endif
-%}

<div class="{{ wrap_class }}" {{ block.shopify_attributes }}>
  {%- if s.button_style == 'arrow' -%}
    <a
      class="cl-arrow-btn cl-arrow-btn--{{ s.arrow_style }}{% unless s.show_label and label != blank %} cl-arrow-btn--icon-only{% endunless %}"
      href="{{ link }}"
      style="--cl-arrow-size: {{ s.arrow_size }}px;"
      aria-label="{{ label | default: collection.title | escape }}"
      {%- if s.open_new_tab %} target="_blank" rel="noopener"{%- endif -%}
    >
      {%- if s.show_label and label != blank -%}
        <span class="cl-arrow-btn__label">{{ label }}</span>
      {%- endif -%}
      {%- if s.arrow_button -%}
        <span class="cl-arrow-btn__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" focusable="false">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </span>
      {%- endif -%}
    </a>
  {%- else -%}
    <a
      class="{{ btn_class }}"
      href="{{ link }}"
      {%- if s.open_new_tab %} target="_blank" rel="noopener"{%- endif -%}
    >
      {{- label -}}
    </a>
  {%- endif -%}
</div>

{% stylesheet %}
.cl-arrow-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  color: inherit;
  text-decoration: none;
  font: inherit;
}
.cl-arrow-btn--icon-only { gap: 0; }
.cl-arrow-btn__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width:  var(--cl-arrow-size, 32px);
  height: var(--cl-arrow-size, 32px);
  flex-shrink: 0;
  transition: transform 0.2s ease, background 0.2s ease;
}
.cl-arrow-btn__icon svg { width: 52%; height: 52%; display: block; }
.cl-arrow-btn--filled-circle .cl-arrow-btn__icon {
  border-radius: 50%;
  background: var(--button-primary-bg);
  color: var(--button-primary-color);
}
.cl-arrow-btn--outline-circle .cl-arrow-btn__icon {
  border-radius: 50%;
  border: 1.5px solid currentColor;
}
.cl-arrow-btn--square .cl-arrow-btn__icon {
  border-radius: 4px;
  background: var(--button-primary-bg);
  color: var(--button-primary-color);
}
.cl-arrow-btn--minimal .cl-arrow-btn__icon {
  width: auto;
  height: auto;
}
@media (prefers-reduced-motion: no-preference) {
  .cl-arrow-btn:hover .cl-arrow-btn__icon { transform: translateX(4px); }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.collection_button.name",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:labels.button_link",
      "info": "t:blocks.collection_button.link_info"
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "t:blocks.collection_button.open_new_tab",
      "default": false
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:labels.button_style",
      "options": [
        { "value": "primary",   "label": "t:options.button_style.primary" },
        { "value": "secondary", "label": "t:options.button_style.secondary" },
        { "value": "link",      "label": "t:options.button_style.link" },
        { "value": "arrow",     "label": "t:options.button_style.arrow" }
      ],
      "default": "primary"
    },
    {
      "type": "checkbox",
      "id": "show_label",
      "label": "t:blocks.collection_button.show_button_label",
      "default": true,
      "info": "t:blocks.collection_button.show_button_label_info",
      "visible_if": "{{ block.settings.button_style == 'arrow' }}"
    },
    {
      "type": "checkbox",
      "id": "arrow_button",
      "label": "t:blocks.collection_button.show_arrow_icon",
      "default": true,
      "visible_if": "{{ block.settings.button_style == 'arrow' }}"
    },
    {
      "type": "select",
      "id": "arrow_style",
      "label": "t:blocks.collection_button.arrow_style",
      "options": [
        { "value": "filled-circle",  "label": "t:options.arrow_style.filled_circle" },
        { "value": "outline-circle", "label": "t:options.arrow_style.outline_circle" },
        { "value": "square",         "label": "t:options.arrow_style.square" },
        { "value": "minimal",        "label": "t:options.arrow_style.minimal" }
      ],
      "default": "filled-circle",
      "visible_if": "{{ block.settings.button_style == 'arrow' }}"
    },
    {
      "type": "range",
      "id": "arrow_size",
      "label": "t:blocks.collection_button.arrow_size",
      "min": 20, "max": 60, "step": 2, "unit": "px",
      "default": 32,
      "visible_if": "{{ block.settings.button_style == 'arrow' }}"
    },
    {
      "type": "header",
      "content": "t:blocks.collection_button.placement_header"
    },
    {
      "type": "select",
      "id": "align",
      "label": "t:labels.horizontal_alignment",
      "options": [
        { "value": "auto",   "label": "t:blocks.collection_button.align_inherit" },
        { "value": "left",   "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right",  "label": "t:options.alignment.right" }
      ],
      "default": "auto"
    },
    {
      "type": "checkbox",
      "id": "pin_bottom",
      "label": "t:blocks.collection_button.pin_bottom",
      "default": false,
      "info": "t:blocks.collection_button.pin_bottom_info"
    }
  ],
  "presets": [
    {
      "name": "t:blocks.collection_button.preset_name"
    }
  ]
}
{% endschema %}
