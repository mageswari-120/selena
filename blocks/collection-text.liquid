{% doc %}
  blocks/collection-text.liquid  —  Selena Theme  (OS 3.0)
  ─────────────────────────────────────────────────────────
  Free merchant-authored inline text rendered as a heading
  (H3–H6) or as a small badge/pill label (e.g. "0–10 Months",
  "1–3 Years").

  Does NOT read closest.collection — the text is fully custom.
{% enddoc %}
 
{%- liquid
  assign s           = block.settings
  assign tag         = s.heading_size
  assign border_alpha = s.border_opacity | divided_by: 100.0
-%}

<{{ tag }} 
  class="cl-text cl-text--{{ s.text_case }}{% if s.display_style == 'badge' %} cl-text--badge{% endif %}"
  style="{% render 'spacing-style', settings: s, prefix: '--cl-text' %}{% if s.border_radius > 0 %} --cl-text-radius: {{ s.border_radius }}px;{% endif %}{% if s.badge_background != blank %} --cl-text-bg: {{ s.badge_background }};{% endif %}{% if s.border_style != 'none' %} --cl-text-border: {{ s.border_width }}px solid rgba(0,0,0,{{ border_alpha }});{% endif %}"
  {{ block.shopify_attributes }}
>
  {{- s.text -}}
</{{ tag }}>

{% stylesheet %}
/* ─────────────────────────────────────────────
   Text Block — block styles
───────────────────────────────────────────── */

.cl-text {
  margin: 0;
  padding-top:    var(--cl-text-pt, 0);
  padding-bottom: var(--cl-text-pb, 0);
  border:         var(--cl-text-border, none);
  border-radius:  var(--cl-text-radius, 0);
  font-family: var(--font-heading--family, inherit);
  font-weight: var(--font-heading--weight, 700);
  color: inherit;
  line-height: 1.2;
}
.cl-text--uppercase { text-transform: uppercase; }

/* Badge / pill label */
.cl-text--badge {
  display: inline-block;
  width: auto;
  padding: 0.35em 0.85em;
  border-radius: var(--cl-text-radius, 999px);
  background: var(--cl-text-bg, rgba(255,255,255,0.72));
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  line-height: 1.1;
}

h3.cl-text { font-size: clamp(1.25rem, 2.6vw, 1.6rem); }
h4.cl-text { font-size: clamp(1.05rem, 2.2vw, 1.25rem); }
h5.cl-text { font-size: 1rem; }
h6.cl-text { font-size: 0.85rem; letter-spacing: 0.04em; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.collection_text.name",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "t:labels.text",
      "default": "Text"
    },
    {
      "type": "select",
      "id": "display_style",
      "label": "t:labels.display_style",
      "options": [
        { "value": "heading", "label": "t:options.display_style.heading" },
        { "value": "badge",   "label": "t:options.display_style.badge" }
      ],
      "default": "heading",
      "info": "t:blocks.collection_text.display_style_info"
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "t:blocks.collection_text.badge_background",
      "info": "t:blocks.collection_text.badge_background_info",
      "visible_if": "{{ block.settings.display_style == 'badge' }}"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:labels.heading_size",
      "options": [
        { "value": "h3", "label": "t:options.heading_level.h3" },
        { "value": "h4", "label": "t:options.heading_level.h4" },
        { "value": "h5", "label": "t:options.heading_level.h5" },
        { "value": "h6", "label": "t:options.heading_level.h6" }
      ],
      "default": "h5"
    },
    {
      "type": "select",
      "id": "text_case",
      "label": "t:labels.text_case",
      "options": [
        { "value": "default",   "label": "t:options.text_case.default" },
        { "value": "uppercase", "label": "t:options.text_case.uppercase" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "t:labels.border"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "t:labels.border_style",
      "options": [
        { "value": "none",  "label": "t:options.border.none" },
        { "value": "solid", "label": "t:options.border.solid" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "t:labels.border_width",
      "min": 1, "max": 5, "step": 1, "unit": "px",
      "default": 1,
      "visible_if": "{{ block.settings.border_style != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "label": "t:labels.border_opacity",
      "min": 0, "max": 100, "step": 1, "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.border_style != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:labels.border_radius",
      "min": 0, "max": 30, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:labels.padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.top_padding",
      "min": 0, "max": 30, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.bottom_padding",
      "min": 0, "max": 30, "step": 1, "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:blocks.collection_text.preset_name"
    }
  ]
}
{% endschema %}
