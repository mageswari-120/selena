{% doc %}
  blocks/collection-description.liquid  —  Selena Theme  (OS 3.0)
  ────────────────────────────────────────────────────────────────
  Fixed slot rendered by the section's content_for 'block' loop.
  Reads closest.collection for description text.

  Section → content_for 'block', id:'cl-desc' → THIS FILE
{% enddoc %}

{%- liquid
  assign s          = block.settings
  assign collection = closest.collection
-%}

<div
  class="cl-collection-description cl-desc--{{ s.text_case }}"
  style="{% render 'spacing-style', settings: s, prefix: '--cl-desc' %}"
  {{ block.shopify_attributes }}
>
  {%- if collection.description != blank -%}
    <div class="cl-desc__body">{{ collection.description }}</div>
  {%- elsif request.design_mode -%}
    <div class="cl-desc__body cl-desc__body--placeholder">
      <p>Collection description will appear here.</p>
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
.cl-collection-description {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding-top:    var(--cl-desc-pt, 0);
  padding-bottom: var(--cl-desc-pb, 0);
  color: inherit;
}
.cl-desc__body {
  opacity: 0.78;
  font-size: 0.9rem;
  line-height: 1.55;
}
.cl-desc__body > :first-child { margin-top: 0; }
.cl-desc__body > :last-child  { margin-bottom: 0; }
.cl-desc__body--placeholder   { opacity: 0.35; font-style: italic; }
.cl-desc--uppercase .cl-desc__body { text-transform: uppercase; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.collection_description.name",
  "settings": [
    {
      "type": "select",
      "id": "text_case",
      "label": "t:labels.text_case",
      "options": [
        { "value": "default",   "label": "t:options.text_case.default" },
        { "value": "uppercase", "label": "t:options.text_case.uppercase" }
      ],
      "default": "default"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.top_padding",
      "min": 0, "max": 30, "step": 1, "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.bottom_padding",
      "min": 0, "max": 30, "step": 1, "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:blocks.collection_description.preset_name"
    }
  ]
}
{% endschema %}
