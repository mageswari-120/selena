{% doc %}
  Renders the testimonial section header area with nested heading, text, and button blocks.

  @example
  {% content_for 'block', type: 'testimonial-header', id: 'testimonial_header' %}
{% enddoc %}

<div
  class="wdt-testimonial__header text-{{ block.settings.alignment }}"
  {{ block.shopify_attributes }}
  style="--wdt-hdr-mb: {{ block.settings.margin_bottom }}px;"
>
  {% content_for 'blocks' %}
</div>

{% stylesheet %}
.wdt-testimonial__header {
  margin-bottom: var(--wdt-hdr-mb, 40px);
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.testimonial_header.name",
  "blocks": [
    { "type": "testimonial-heading" },
    { "type": "testimonial-text" },
    { "type": "testimonial-button" }
  ],
  "settings": [
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "start",  "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "end",    "label": "t:options.alignment.right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "t:blocks.testimonial_header.bottom_spacing",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "t:blocks.testimonial_header.preset_name"
    }
  ]
}
{% endschema %}
