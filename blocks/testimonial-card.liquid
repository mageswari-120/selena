{% doc %}
  blocks/testimonial-card.liquid  —  Selena Theme  (OS 3.0)
  Parent: blocks/testimonial-content.liquid via content_for 'blocks'
  Children: testimonial-image · testimonial-heading · testimonial-text
            testimonial-rating · testimonial-client
  Carousel slides: OS 3.0 wraps cards in .shopify-block; swiper-slide added in collection-list-carousel.js
{% enddoc %}

{%- liquid
  assign card_type      = block.settings.card_type      | default: 'grid'
  assign img_pos        = block.settings.card_image_position | default: 'top'
  assign alignment      = block.settings.card_alignment  | default: 'center'
  assign card_gap       = block.settings.card_gap        | default: 10
  assign border_style   = block.settings.card_border_style   | default: 'none'
  assign border_width   = block.settings.card_border_width   | default: 1
  assign border_opacity = block.settings.card_border_opacity | default: 100 | divided_by: 100.0
  assign border_radius  = block.settings.card_border_radius  | default: 0
  assign enable_overlay = block.settings.enable_overlay  | default: false
  assign inherit_scheme = block.settings.inherit_color_scheme | default: true
  assign card_scheme    = block.settings.card_color_scheme

  if border_style == 'solid'
    assign border_css = border_width | append: 'px solid rgba(0,0,0,' | append: border_opacity | append: ')'
  else
    assign border_css = 'none'
  endif

  if enable_overlay
    assign ov_color = block.settings.overlay_color | default: '#000000'
    if block.settings.overlay_style == 'gradient'
      assign ov_dir = block.settings.overlay_direction | default: 'to bottom'
      assign overlay_css = 'linear-gradient(' | append: ov_dir | append: ', ' | append: ov_color | append: 'cc, transparent)'
    else
      assign overlay_css = ov_color | append: '26'
    endif
  else
    assign overlay_css = 'transparent'
  endif

  unless inherit_scheme
    assign scheme_class = 'color-' | append: card_scheme
  else
    assign scheme_class = ''
  endunless

  assign card_classes = 'wdt-card wdt-card--' | append: card_type
  if card_type == 'grid'
    assign card_classes = card_classes | append: ' wdt-card--img-' | append: img_pos
  endif
  assign card_classes = card_classes | append: ' ' | append: scheme_class | append: ' text-' | append: alignment
-%}

<article
  class="{{ card_classes }}"
  role="listitem"
  {{ block.shopify_attributes }}
  style="
    --wdt-card-gap: {{ card_gap }}px;
    --wdt-card-pt: {{ block.settings.card_pt | default: 20 }}px;
    --wdt-card-pb: {{ block.settings.card_pb | default: 20 }}px;
    --wdt-card-pl: {{ block.settings.card_pl | default: 20 }}px;
    --wdt-card-pr: {{ block.settings.card_pr | default: 20 }}px;
    --wdt-card-border: {{ border_css }};
    --wdt-card-radius: {{ border_radius }}px;
    --wdt-card-overlay: {{ overlay_css }};
  "
>
  {%- if enable_overlay -%}
    <div class="wdt-card__overlay" aria-hidden="true"></div>
  {%- endif -%}

  <div class="wdt-card__inner">
    {% content_for 'blocks' %}
  </div>
</article>

{% stylesheet %}
.wdt-card {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100%;
  padding-top: var(--wdt-card-pt, 20px);
  padding-bottom: var(--wdt-card-pb, 20px);
  padding-left: var(--wdt-card-pl, 20px);
  padding-right: var(--wdt-card-pr, 20px);
  border: var(--wdt-card-border, none);
  border-radius: var(--wdt-card-radius, 0px);
  overflow: hidden;
  background-color: var(--color-background, #fff);
  color: var(--color-foreground, #1a1a1a);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}
.wdt-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 30px rgba(0,0,0,.08);
}
.wdt-card__overlay {
  position: absolute; inset: 0;
  background: var(--wdt-card-overlay, transparent);
  pointer-events: none; z-index: 0;
}
.wdt-card__inner {
  position: relative; z-index: 1;
  display: flex; flex-direction: column;
  flex: 1;
  gap: var(--wdt-card-gap, 10px);
}
.wdt-card--grid.wdt-card--img-top    { flex-direction: column; }
.wdt-card--grid.wdt-card--img-bottom { flex-direction: column-reverse; }
.wdt-card--grid.wdt-card--img-left  {
  flex-direction: row; align-items: flex-start;
}
.wdt-card--grid.wdt-card--img-right {
  flex-direction: row-reverse; align-items: flex-start;
}
.wdt-card--grid.wdt-card--img-left .wdt-card__inner,
.wdt-card--grid.wdt-card--img-right .wdt-card__inner { flex: 1; }
.wdt-card--overlay {
  position: relative;
  min-height: 280px;
}
.wdt-card--overlay .wdt-card__inner {
  position: relative;
  z-index: 2;
  min-height: 280px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  flex: 1;
}
.wdt-card--overlay .wdt-card__image-wrap {
  position: absolute;
  inset: 0;
  padding: 0 !important;
  z-index: 0;
}
.wdt-card--overlay .wdt-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.wdt-card--overlay .wdt-card__rating,
.wdt-card--overlay .wdt-card__heading,
.wdt-card--overlay .wdt-card__desc,
.wdt-card--overlay .wdt-card__client {
  position: relative;
  z-index: 1;
}
@media (max-width: 575.98px) {
  .wdt-card--grid.wdt-card--img-left,
  .wdt-card--grid.wdt-card--img-right {
    flex-direction: column;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.testimonial_card.name",
  "blocks": [
    { "type": "testimonial-image" },
    { "type": "testimonial-heading" },
    { "type": "testimonial-text" },
    { "type": "testimonial-rating" },
    { "type": "testimonial-client" }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:blocks.testimonial_card.headers.card_layout"
    },
    {
      "type": "select",
      "id": "card_type",
      "label": "t:blocks.testimonial_card.card_type",
      "options": [
        { "value": "grid",    "label": "t:options.card_layout.grid" },
        { "value": "overlay", "label": "t:options.card_layout.overlay" }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "card_image_position",
      "label": "t:blocks.testimonial_card.card_image_position",
      "info": "t:blocks.testimonial_card.card_image_position_info",
      "options": [
        { "value": "top",    "label": "t:options.image_position_card.top" },
        { "value": "bottom", "label": "t:options.image_position_card.bottom" },
        { "value": "left",   "label": "t:options.image_position_card.left" },
        { "value": "right",  "label": "t:options.image_position_card.right" }
      ],
      "default": "top",
      "visible_if": "{{ block.settings.card_type == 'grid' }}"
    },
    {
      "type": "select",
      "id": "card_alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "start",  "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "end",    "label": "t:options.alignment.right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "t:blocks.testimonial_card.card_gap",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "t:blocks.testimonial_card.headers.appearance"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "t:blocks.testimonial_card.enable_overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:blocks.testimonial_card.overlay_color",
      "default": "#000000",
      "visible_if": "{{ block.settings.enable_overlay == true }}"
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "t:blocks.testimonial_card.overlay_style",
      "options": [
        { "value": "solid",    "label": "t:options.overlay_style.solid" },
        { "value": "gradient", "label": "t:options.overlay_style.gradient" }
      ],
      "default": "solid",
      "visible_if": "{{ block.settings.enable_overlay == true }}"
    },
    {
      "type": "select",
      "id": "overlay_direction",
      "label": "t:blocks.testimonial_card.overlay_direction",
      "options": [
        { "value": "to bottom", "label": "t:options.overlay_direction.top_bottom" },
        { "value": "to top",    "label": "t:options.overlay_direction.bottom_top" }
      ],
      "default": "to bottom",
      "visible_if": "{{ block.settings.enable_overlay == true and block.settings.overlay_style == 'gradient' }}"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:blocks.testimonial_card.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "t:blocks.testimonial_card.headers.border"
    },
    {
      "type": "select",
      "id": "card_border_style",
      "label": "t:labels.border_style",
      "options": [
        { "value": "none",  "label": "t:options.border.none" },
        { "value": "solid", "label": "t:options.border.solid" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "t:labels.border_width",
      "min": 1, "max": 5, "step": 1, "unit": "px",
      "default": 1,
      "visible_if": "{{ block.settings.card_border_style == 'solid' }}"
    },
    {
      "type": "range",
      "id": "card_border_opacity",
      "label": "t:labels.border_opacity",
      "min": 0, "max": 100, "step": 5, "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.card_border_style == 'solid' }}"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "t:labels.border_radius",
      "min": 0, "max": 30, "step": 1, "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.card_border_style == 'solid' }}"
    },
    {
      "type": "header",
      "content": "t:blocks.testimonial_card.headers.padding"
    },
    {
      "type": "range",
      "id": "card_pt",
      "label": "t:labels.top_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_pb",
      "label": "t:labels.bottom_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_pl",
      "label": "t:labels.left_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_pr",
      "label": "t:labels.right_padding",
      "min": 0, "max": 50, "step": 2, "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:blocks.testimonial_card.preset_name"
    }
  ]
}
{% endschema %}
